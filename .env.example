# Pinecone: API key from https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key

# OpenRouter: API key from https://openrouter.ai/keys
# Used as fallback if GROQ_API_KEY is not set
OPENROUTER_API_KEY=your-openrouter-api-key

# Groq: API key from https://console.groq.com (primary LLM — fast, free tier)
GROQ_API_KEY=your-groq-api-key

# Telegram Bot: Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Neon Postgres: Connection URL from https://neon.tech
# Comment out or leave unset to use local SQLite instead
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# Flask secret key for session management
# SECRET_KEY=your-secret-key