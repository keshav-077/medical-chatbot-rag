    },
    "var_3b07ccc96140": {
      "type": "variant",
      "label": "Variant C: Deep Space Neumorphism (Clinical Indigo)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 4140,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "<div class=\"w-[1280px] h-[800px] bg-[#1E2952] text-slate-100 flex overflow-hidden p-6 gap-6 relative select-none font-sans\" style=\"--space-indigo: #1E2952; --dark-amethyst: #32174D; --bright-lavender: #B57EDC;\" data-kid=\"0\">\n  \n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n    .font-sans {\n      font-family: 'Plus Jakarta Sans', sans-serif;\n    }\n    .font-mono-tech {\n      font-family: 'IBM Plex Sans', sans-serif;\n    }\n\n    /* Custom Neumorphism Styles mapped to Deep Space Indigo background */\n    /* Light source from top-left. Since background is #1E2952, we use a darker shadow-indigo/black for bottom-right shadow, and a lighter purple-ish glow for top-left highlight */\n    .neomorph-raised {\n      background-color: #1E2952;\n      box-shadow: \n        8px 8px 20px rgba(8, 11, 26, 0.95), \n        -8px -8px 20px rgba(62, 83, 161, 0.28),\n        inset 1px 1px 0px rgba(255, 255, 255, 0.08);\n    }\n\n    .neomorph-raised-interactive {\n      background-color: #1E2952;\n      box-shadow: \n        6px 6px 14px rgba(8, 11, 26, 0.85), \n        -6px -6px 14px rgba(62, 83, 161, 0.22),\n        inset 1px 1px 0px rgba(255, 255, 255, 0.06);\n      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n    .neomorph-raised-interactive:hover {\n      box-shadow: \n        8px 8px 16px rgba(11, 16, 36, 0.9), \n        -8px -8px 16px rgba(62, 83, 161, 0.3),\n        inset 1px 1px 0px rgba(255, 255, 255, 0.1);\n      transform: translateY(-1px);\n    }\n    .neomorph-raised-interactive:active {\n      box-shadow: \n        inset 4px 4px 10px rgba(11, 16, 36, 0.9), \n        inset -4px -4px 10px rgba(62, 83, 161, 0.15);\n      transform: translateY(1px);\n    }\n\n    .neomorph-inset {\n      background-color: #161E3E; /* slightly deeper than space indigo for the recessed look */\n      box-shadow: \n        inset 6px 6px 14px rgba(6, 8, 20, 0.98), \n        inset -6px -6px 14px rgba(62, 83, 161, 0.18);\n    }\n\n    .neomorph-inset-darker {\n      background-color: #0F152C;\n      box-shadow: \n        inset 8px 8px 18px rgba(4, 5, 14, 0.98), \n        inset -8px -8px 18px rgba(62, 83, 161, 0.12);\n    }\n\n    .neomorph-btn-purple {\n      background-color: #32174D;\n      box-shadow: \n        5px 5px 12px rgba(11, 16, 36, 0.8), \n        -5px -5px 12px rgba(181, 126, 220, 0.15),\n        inset 1px 1px 0px rgba(181, 126, 220, 0.2);\n      transition: all 0.15s ease;\n    }\n    .neomorph-btn-purple:hover {\n      background-color: #3D1C5E;\n      box-shadow: \n        6px 6px 14px rgba(11, 16, 36, 0.9), \n        -6px -6px 14px rgba(181, 126, 220, 0.25),\n        inset 1px 1px 0px rgba(181, 126, 220, 0.3);\n    }\n    .neomorph-btn-purple:active {\n      box-shadow: \n        inset 4px 4px 10px rgba(11, 16, 36, 0.9), \n        inset -4px -4px 10px rgba(181, 126, 220, 0.1);\n    }\n\n    /* Pulse effects */\n    @keyframes pulse-slow {\n      0%, 100% { opacity: 0.4; transform: scale(1); }\n      50% { opacity: 0.8; transform: scale(1.06); }\n    }\n    .glow-pulse {\n      animation: pulse-slow 3s infinite ease-in-out;\n    }\n\n    /* ECG Simulation styling */\n    .ecg-line {\n      stroke: #B57EDC;\n      stroke-width: 2.5;\n      stroke-linecap: round;\n      stroke-linejoin: round;\n      opacity: 0.95;\n    }\n    \n    /* Input placeholder styling compatibility override */\n    input::placeholder {\n      color: rgba(226, 232, 240, 0.5) !important;\n    }\n  </style>\n\n  \n  <aside class=\"w-72 shrink-0 flex flex-col h-full justify-between p-5 rounded-2xl neomorph-inset\" data-kid=\"2\">\n    \n    \n    <div data-kid=\"3\">\n      <div class=\"flex items-center gap-3 mb-6 px-1\" data-kid=\"4\">\n        <div class=\"w-10 h-10 rounded-xl neomorph-raised flex items-center justify-center text-[#B57EDC]\" data-kid=\"5\">\n          <i class=\"ti ti-activity-heartbeat text-xl\" data-kid=\"6\"></i>\n        </div>\n        <div data-kid=\"7\">\n          <h2 class=\"text-xs font-semibold uppercase tracking-wider text-[#B57EDC]/80 font-mono-tech\" data-kid=\"8\">MED-OS Platform</h2>\n          <span class=\"text-sm font-bold text-slate-100\" data-kid=\"9\">Quantum Clinical v4.2</span>\n        </div>\n      </div>\n\n      \n      <div class=\"p-3.5 rounded-xl bg-[#161E3E]/60 border border-[#B57EDC]/15 flex items-center gap-3 mb-6\" data-kid=\"10\">\n        <div class=\"relative shrink-0\" data-kid=\"11\">\n          <img src=\"https://i.pravatar.cc/100?u=dr_kesav\" alt=\"Dr. Kesavardhan\" class=\"w-11 h-11 rounded-lg border-2 border-[#B57EDC]/40 object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"12\">\n          <span class=\"absolute -bottom-1 -right-1 w-3.5 h-3.5 bg-emerald-500 rounded-full border-2 border-[#1E2952]\" data-kid=\"13\"></span>\n        </div>\n        <div class=\"overflow-hidden\" data-kid=\"14\">\n          <p class=\"text-[10px] text-[#B57EDC]/90 font-bold font-mono-tech tracking-wider\" data-kid=\"15\">CLINICIAN ID: #775</p>\n          <p class=\"text-sm font-bold text-slate-100 truncate\" data-kid=\"16\">Dr. K. Makireddi</p>\n          <p class=\"text-[10px] text-slate-300 font-mono-tech truncate\" data-kid=\"17\">kesavardhan775@gmail.com</p>\n        </div>\n      </div>\n\n      \n      <button class=\"w-full py-3 px-4 rounded-xl neomorph-btn-purple text-slate-100 font-bold flex items-center justify-center gap-2 text-sm transition-all cursor-pointer font-sans mb-6\" data-kid=\"18\">\n        <i class=\"ti ti-plus text-base\" data-kid=\"19\"></i>\n        <span data-kid=\"20\">Initiate New Session</span>\n      </button>\n\n      \n      <div data-kid=\"21\">\n        <div class=\"flex items-center justify-between px-1 mb-3\" data-kid=\"22\">\n          <span class=\"text-[11px] font-bold uppercase tracking-wider text-slate-400 font-mono-tech\" data-kid=\"23\">Active Diagnostics</span>\n          <span class=\"px-1.5 py-0.5 rounded text-[10px] font-bold bg-[#32174D] text-[#B57EDC] font-mono-tech\" data-kid=\"24\">3 RUNNING</span>\n        </div>\n\n        <nav class=\"space-y-3\" data-kid=\"25\">\n          \n          <div class=\"p-3 rounded-xl bg-[#1E2952] border border-[#B57EDC]/45 shadow-[inset_1px_1px_0px_rgba(255,255,255,0.08)] cursor-pointer\" data-kid=\"26\">\n            <div class=\"flex items-center justify-between mb-1\" data-kid=\"27\">\n              <span class=\"text-[11px] font-bold text-[#B57EDC] font-mono-tech\" data-kid=\"28\">DIAG_ID_9082</span>\n              <span class=\"text-[10px] text-[#B57EDC]/90 font-mono-tech font-semibold\" data-kid=\"29\">2 min ago</span>\n            </div>\n            <p class=\"text-xs font-bold text-slate-100 truncate\" data-kid=\"30\">Cardiovascular Risk assessment</p>\n          </div>\n\n          \n          <div class=\"p-3 rounded-xl hover:bg-[#1E2952]/40 border border-transparent hover:border-slate-700/20 cursor-pointer transition-all\" data-kid=\"31\">\n            <div class=\"flex items-center justify-between mb-1\" data-kid=\"32\">\n              <span class=\"text-[11px] font-bold text-slate-400 font-mono-tech\" data-kid=\"33\">DIAG_ID_8741</span>\n              <span class=\"text-[10px] text-slate-500 font-mono-tech\" data-kid=\"34\">1.5 hrs ago</span>\n            </div>\n            <p class=\"text-xs text-slate-300 truncate\" data-kid=\"35\">Neurology EEG Spectral Scan</p>\n          </div>\n\n          \n          <div class=\"p-3 rounded-xl hover:bg-[#1E2952]/40 border border-transparent hover:border-slate-700/20 cursor-pointer transition-all\" data-kid=\"36\">\n            <div class=\"flex items-center justify-between mb-1\" data-kid=\"37\">\n              <span class=\"text-[11px] font-bold text-slate-400 font-mono-tech\" data-kid=\"38\">DIAG_ID_8629</span>\n              <span class=\"text-[10px] text-slate-500 font-mono-tech\" data-kid=\"39\">Yesterday</span>\n            </div>\n            <p class=\"text-xs text-slate-300 truncate\" data-kid=\"40\">Pulmonary Fibrosis Screening</p>\n          </div>\n        </nav>\n      </div>\n    </div>\n\n    \n    <div class=\"pt-4 border-t border-slate-800/40\" data-kid=\"41\">\n      <button class=\"w-full flex items-center justify-between px-3 py-2 rounded-lg text-slate-400 hover:text-rose-400 hover:bg-rose-500/10 transition-colors text-xs font-bold uppercase tracking-wider font-mono-tech cursor-pointer\" data-kid=\"42\">\n        <span data-kid=\"43\">Terminate Platform Session</span>\n        <i class=\"ti ti-logout text-base\" data-kid=\"44\"></i>\n      </button>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 flex flex-col h-full justify-between rounded-2xl neomorph-inset p-5 relative\" data-kid=\"45\">\n    \n    \n    <div class=\"flex items-center justify-between pb-4 border-b border-slate-800/60 z-10\" data-kid=\"46\">\n      <div class=\"flex items-center gap-3\" data-kid=\"47\">\n        <div class=\"w-3 h-3 rounded-full bg-emerald-500 shadow-[0_0_8px_#10b981]\" data-kid=\"48\"></div>\n        <div data-kid=\"49\">\n          <h1 class=\"text-base font-bold text-slate-100 font-sans\" data-kid=\"50\">Dynamic Core Diagnostic Interface</h1>\n          <p class=\"text-[11px] font-mono-tech text-slate-400 uppercase tracking-widest\" data-kid=\"51\">SECURE SUITE • ENCRYPTED BIO-BRIDGE</p>\n        </div>\n      </div>\n      \n      \n      <div class=\"relative flex items-center\" data-kid=\"52\">\n        <div class=\"absolute -inset-1 rounded-full bg-[#B57EDC]/20 blur-md glow-pulse\" data-kid=\"53\"></div>\n        <div class=\"relative flex items-center gap-2 px-3 py-1.5 rounded-full bg-[#32174D]/80 border border-[#B57EDC]/40 text-xs text-[#B57EDC] font-mono-tech font-bold\" data-kid=\"54\">\n          <i class=\"ti ti-shield-check text-sm\" data-kid=\"55\"></i>\n          <span data-kid=\"56\">HIPAA COMPLIANT</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"flex-1 flex flex-col items-center justify-center py-6 px-10 text-center z-10\" data-kid=\"57\">\n      <div class=\"w-24 h-24 rounded-3xl neomorph-raised flex items-center justify-center mb-6 relative\" data-kid=\"58\">\n        \n        <div class=\"absolute inset-0 bg-[#B57EDC]/15 rounded-3xl glow-pulse filter blur-xl\" data-kid=\"59\"></div>\n        <div class=\"w-16 h-16 rounded-2xl bg-[#32174D] flex items-center justify-center text-[#B57EDC] border border-[#B57EDC]/35\" data-kid=\"60\">\n          <i class=\"ti ti-cpu text-5xl animate-pulse\" data-kid=\"61\"></i>\n        </div>\n      </div>\n\n      <h3 class=\"text-xl font-extrabold text-slate-100 tracking-tight font-sans mb-2\" data-kid=\"62\">Initiate Advanced Clinical Dialogue</h3>\n      <p class=\"text-sm text-slate-300 max-w-md font-mono-tech leading-relaxed mb-6\" data-kid=\"63\">\n        Submit patient history, diagnostic images, or biochemical panel outputs. The AI assistant will formulate cross-referenced analytical diagnostic hypotheses instantly.\n      </p>\n\n      \n      <div class=\"flex flex-wrap gap-2.5 justify-center max-w-lg\" data-kid=\"64\">\n        <button class=\"px-3 py-2 rounded-lg neomorph-raised-interactive text-xs font-mono-tech font-semibold text-[#B57EDC] border border-[#B57EDC]/25 cursor-pointer hover:bg-[#32174D]/20\" data-kid=\"65\">\n          [PARSE] Chest X-Ray DICOM\n        </button>\n        <button class=\"px-3 py-2 rounded-lg neomorph-raised-interactive text-xs font-mono-tech font-semibold text-[#B57EDC] border border-[#B57EDC]/25 cursor-pointer hover:bg-[#32174D]/20\" data-kid=\"66\">\n          [EVAL] Complex Lipid Panel\n        </button>\n        <button class=\"px-3 py-2 rounded-lg neomorph-raised-interactive text-xs font-mono-tech font-semibold text-[#B57EDC] border border-[#B57EDC]/25 cursor-pointer hover:bg-[#32174D]/20\" data-kid=\"67\">\n          [HYPOTHESIZE] Chronic Cephalea\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"pt-4 border-t border-slate-800/60 z-10\" data-kid=\"68\">\n      <div class=\"flex items-center gap-4\" data-kid=\"69\">\n        \n        <div class=\"flex-1 h-14 rounded-xl neomorph-inset-darker flex items-center px-4 border border-slate-800/60\" data-kid=\"70\">\n          <input type=\"text\" placeholder=\"Type your medical query or drop clinical telemetry here...\" class=\"w-full bg-transparent border-none text-slate-100 placeholder-slate-200/50 focus:outline-hidden text-sm font-mono-tech\" data-kid=\"71\">\n          <div class=\"flex items-center gap-2 shrink-0\" data-kid=\"72\">\n            <button class=\"p-2 rounded-lg text-slate-400 hover:text-[#B57EDC] transition-colors cursor-pointer\" title=\"Attach Medical File\" data-kid=\"73\">\n              <i class=\"ti ti-photo-video text-xl\" data-kid=\"74\"></i>\n            </button>\n          </div>\n        </div>\n\n        \n        <button class=\"w-14 h-14 rounded-full neomorph-btn-purple flex items-center justify-center shrink-0 cursor-pointer text-[#B57EDC] transition-transform hover:scale-105 active:scale-95\" title=\"Transmit Query\" data-kid=\"75\">\n          <i class=\"ti ti-arrow-up text-2xl\" data-kid=\"76\"></i>\n        </button>\n      </div>\n      <p class=\"text-[10px] text-center text-slate-500 font-mono-tech mt-3 uppercase tracking-wider\" data-kid=\"77\">\n        BIO-TELEMETRY SYNC ACTIVE • ALL DATA IS SHIELDED VIA END-TO-END QUANTUM ENCRYPTION\n      </p>\n    </div>\n  </main>\n\n  \n  <aside class=\"w-80 shrink-0 flex flex-col h-full rounded-2xl neomorph-raised p-5 justify-between relative overflow-hidden\" data-kid=\"78\">\n    \n    \n    <div data-kid=\"79\">\n      <div class=\"flex items-center justify-between pb-3 border-b border-slate-800/60 mb-4\" data-kid=\"80\">\n        <div class=\"flex items-center gap-2\" data-kid=\"81\">\n          <i class=\"ti ti-activity text-[#B57EDC] text-lg\" data-kid=\"82\"></i>\n          <h2 class=\"text-sm font-bold text-slate-100 font-sans\" data-kid=\"83\">Diagnostic Canvas</h2>\n        </div>\n        <span class=\"text-[10px] font-mono-tech bg-rose-500/10 text-rose-400 border border-rose-500/20 px-1.5 py-0.5 rounded\" data-kid=\"84\">REALTIME</span>\n      </div>\n\n      \n      <div class=\"mb-5 p-3 rounded-xl neomorph-inset\" data-kid=\"85\">\n        <div class=\"flex items-center justify-between mb-2\" data-kid=\"86\">\n          <span class=\"text-[10px] font-bold text-slate-400 font-mono-tech uppercase\" data-kid=\"87\">Live ECG Telemetry</span>\n          <span class=\"text-[11px] font-bold text-[#B57EDC] font-mono-tech\" data-kid=\"88\">72 BPM</span>\n        </div>\n        <div class=\"w-full h-14 bg-[#0F152C] rounded-lg overflow-hidden relative flex items-center justify-center\" data-kid=\"89\">\n          \n          <div class=\"absolute inset-0 opacity-[0.04]\" style=\"background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 8px 8px;\" data-kid=\"90\"></div>\n          \n          <svg class=\"w-full h-full\" viewBox=\"0 0 280 60\" data-kid=\"91\">\n            <path class=\"ecg-line\" d=\"M 0 30 L 40 30 L 50 30 L 55 15 L 60 45 L 65 30 L 80 30 L 110 30 L 115 5 L 122 55 L 128 30 L 140 30 L 180 30 L 190 30 L 195 18 L 200 42 L 205 30 L 220 30 L 250 30 L 255 8 L 262 52 L 268 30 L 280 30\" fill=\"none\" data-kid=\"92\"></path>\n          </svg>\n        </div>\n      </div>\n\n      \n      <div class=\"space-y-4\" data-kid=\"93\">\n        <div class=\"flex items-center justify-between\" data-kid=\"94\">\n          <span class=\"text-[11px] font-bold uppercase tracking-wider text-slate-400 font-mono-tech\" data-kid=\"95\">Capability Ledger</span>\n          <span class=\"text-[10px] text-slate-400 font-mono-tech\" data-kid=\"96\">VERIFIED REF_OS</span>\n        </div>\n\n        <div class=\"space-y-2.5\" data-kid=\"97\">\n          \n          <div class=\"flex justify-between items-center py-2 border-b border-slate-800/40\" data-kid=\"98\">\n            <div data-kid=\"99\">\n              <p class=\"text-xs font-bold text-slate-200 font-sans\" data-kid=\"100\">Cognitive Synthesis</p>\n              <p class=\"text-[10px] text-slate-500 font-mono-tech\" data-kid=\"101\">MED-KNOWLEDGE-DB</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"102\">\n              <span class=\"text-xs font-bold text-[#B57EDC] font-mono-tech\" data-kid=\"103\">99.8% ACC</span>\n            </div>\n          </div>\n\n          \n          <div class=\"flex justify-between items-center py-2 border-b border-slate-800/40\" data-kid=\"104\">\n            <div data-kid=\"105\">\n              <p class=\"text-xs font-bold text-slate-200 font-sans\" data-kid=\"106\">Differential Matrix</p>\n              <p class=\"text-[10px] text-slate-500 font-mono-tech\" data-kid=\"107\">CROSS-EVAL-ENGINE</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"108\">\n              <span class=\"text-xs font-bold text-[#B57EDC] font-mono-tech\" data-kid=\"109\">COMPLETED</span>\n            </div>\n          </div>\n\n          \n          <div class=\"flex justify-between items-center py-2 border-b border-slate-800/40\" data-kid=\"110\">\n            <div data-kid=\"111\">\n              <p class=\"text-xs font-bold text-slate-200 font-sans\" data-kid=\"112\">Bio-Agent Synthesis</p>\n              <p class=\"text-[10px] text-slate-500 font-mono-tech\" data-kid=\"113\">RECEPTOR-BOUNDING</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"114\">\n              <span class=\"text-xs font-bold text-amber-400 font-mono-tech\" data-kid=\"115\">ACTIVE HYPO</span>\n            </div>\n          </div>\n\n          \n          <div class=\"flex justify-between items-center py-2 border-b border-slate-800/40\" data-kid=\"116\">\n            <div data-kid=\"117\">\n              <p class=\"text-xs font-bold text-slate-200 font-sans\" data-kid=\"118\">Genome Mapping</p>\n              <p class=\"text-[10px] text-slate-500 font-mono-tech\" data-kid=\"119\">VARIANT_ALIGN_4</p>\n            </div>\n            <div class=\"text-right\" data-kid=\"120\">\n              <span class=\"text-xs font-bold text-emerald-400 font-mono-tech\" data-kid=\"121\">STABLE</span>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"p-3.5 rounded-xl bg-[#32174D]/40 border border-[#B57EDC]/10\" data-kid=\"122\">\n      <div class=\"flex items-center gap-3 mb-2\" data-kid=\"123\">\n        <div class=\"w-2 h-2 rounded-full bg-emerald-500 animate-ping\" data-kid=\"124\"></div>\n        <span class=\"text-xs font-bold font-sans text-slate-200\" data-kid=\"125\">System Diagnostic Integrity</span>\n      </div>\n      <p class=\"text-[10px] text-slate-400 font-mono-tech leading-relaxed\" data-kid=\"126\">\n        Model version <span class=\"text-slate-200\" data-kid=\"127\">MED-Llama-70B-v4</span>. Telemetry latency <span class=\"text-slate-200\" data-kid=\"128\">14ms</span>. Core temperature within normal ranges.\n      </p>\n    </div>\n\n  </aside>\n\n</div>",
