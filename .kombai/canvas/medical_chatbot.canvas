      "html": "<div class=\"w-[1280px] h-[800px] bg-[#010B13] text-slate-100 flex p-4 gap-4 overflow-hidden font-sans relative\" style=\"--cyan-glow: #0FFFFF; --ocean-deep: #1164B4;\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap');\n    \n    .font-tech {\n      font-family: 'Space Grotesk', sans-serif;\n    }\n    .font-sans {\n      font-family: 'Inter', sans-serif;\n    }\n    \n    /* Cybernetic cut-corner card */\n    .cyber-panel {\n      clip-path: polygon(12px 0, calc(100% - 12px) 0, 100% 12px, 100% calc(100% - 12px), calc(100% - 12px) 100%, 12px 100%, 0 calc(100% - 12px), 0 12px);\n    }\n    \n    @keyframes pulse-glow {\n      0%, 100% { opacity: 0.8; filter: drop-shadow(0 0 4px rgba(15, 255, 255, 0.6)); }\n      50% { opacity: 1; filter: drop-shadow(0 0 15px rgba(15, 255, 255, 1)); }\n    }\n    .neon-pulse {\n      animation: pulse-glow 2s infinite ease-in-out;\n    }\n\n    /* Glowing scrollbar */\n    .custom-scroll::-webkit-scrollbar {\n      width: 4px;\n    }\n    .custom-scroll::-webkit-scrollbar-track {\n      background: rgba(255, 255, 255, 0.02);\n    }\n    .custom-scroll::-webkit-scrollbar-thumb {\n      background: rgba(15, 255, 255, 0.3);\n      border-radius: 2px;\n    }\n    .custom-scroll::-webkit-scrollbar-thumb:hover {\n      background: rgba(15, 255, 255, 0.6);\n    }\n  </style>\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"2\">\n\n  \n  <div class=\"absolute top-[-10%] left-[20%] w-[500px] h-[500px] bg-[#1164B4]/10 rounded-full blur-[120px] pointer-events-none\" data-kid=\"3\"></div>\n  <div class=\"absolute bottom-[-10%] right-[10%] w-[600px] h-[600px] bg-[#0FFFFF]/5 rounded-full blur-[150px] pointer-events-none\" data-kid=\"4\"></div>\n\n  \n  <aside class=\"w-[250px] h-full flex flex-col gap-4 shrink-0\" data-kid=\"5\">\n    \n    <div class=\"cyber-panel bg-white/5 backdrop-blur-xl shadow-[inset_0_0_0_1px_rgba(255,255,255,0.12)] p-4 flex items-center gap-3 relative group\" data-kid=\"6\">\n      <div class=\"absolute top-0 left-0 w-[2px] h-full bg-[#0FFFFF] shadow-[0_0_8px_#0FFFFF]\" data-kid=\"7\"></div>\n      <div class=\"relative\" data-kid=\"8\">\n        <img class=\"w-10 h-10 rounded-full border border-white/20\" src=\"https://i.pravatar.cc/100?u=dr_vance\" alt=\"Dr. Vance\" decoding=\"async\" loading=\"lazy\" data-kid=\"9\">\n        <span class=\"absolute bottom-0 right-0 w-2.5 h-2.5 bg-emerald-500 border-2 border-[#010B13] rounded-full\" data-kid=\"10\"></span>\n      </div>\n      <div class=\"min-w-0\" data-kid=\"11\">\n        <h4 class=\"font-tech text-sm font-semibold tracking-wide text-white truncate\" data-kid=\"12\">Dr. K. Vance</h4>\n        <p class=\"text-[10px] text-slate-400 font-mono tracking-wider\" data-kid=\"13\">NEURAL CLINICIAN</p>\n      </div>\n    </div>\n\n    \n    <div class=\"cyber-panel bg-white/5 backdrop-blur-xl shadow-[inset_0_0_0_1px_rgba(255,255,255,0.12)] p-4 flex-1 flex flex-col min-h-0 relative\" data-kid=\"14\">\n      \n      <div class=\"absolute top-0 bottom-0 left-0 w-[1.5px] bg-gradient-to-b from-[#1164B4]/50 to-transparent\" data-kid=\"15\"></div>\n\n      \n      <button class=\"w-full py-3 px-4 rounded-lg bg-gradient-to-r from-[#1164B4]/20 to-white/5 hover:from-[#1164B4]/30 hover:to-[#0FFFFF]/15 border border-white/10 hover:border-[#0FFFFF]/50 text-white hover:text-[#0FFFFF] hover:shadow-[0_0_12px_rgba(15,255,255,0.2)] transition-all duration-300 flex items-center justify-center gap-2 font-tech font-medium tracking-wide text-sm mb-4 cursor-pointer\" data-kid=\"16\">\n        <i class=\"ti ti-message-plus text-base\" data-kid=\"17\"></i>\n        <span data-kid=\"18\">NEW DIAGNOSIS</span>\n      </button>\n\n      \n      <div class=\"flex items-center justify-between text-[11px] font-mono tracking-widest text-slate-400 mb-3 px-1\" data-kid=\"19\">\n        <span data-kid=\"20\">RECENT THREADS</span>\n        <i class=\"ti ti-history text-xs text-slate-500\" data-kid=\"21\"></i>\n      </div>\n\n      \n      <div class=\"flex-1 overflow-y-auto custom-scroll space-y-3 pr-1\" data-kid=\"22\">\n        \n        <div class=\"relative p-3 rounded bg-white/5 border-l-2 border-[#0FFFFF] hover:bg-white/10 transition-colors cursor-pointer group\" data-kid=\"23\">\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"24\">\n            <span class=\"font-tech text-xs text-white font-medium truncate pr-2\" data-kid=\"25\">Neural Cardiopulmonary</span>\n            <span class=\"text-[9px] font-mono text-[#0FFFFF]\" data-kid=\"26\">ACTIVE</span>\n          </div>\n          <p class=\"text-[10px] text-slate-400 truncate\" data-kid=\"27\">Symptom analysis of acute arrhythmia...</p>\n        </div>\n\n        \n        <div class=\"p-3 rounded bg-transparent border-l-2 border-transparent hover:border-slate-500 hover:bg-white/5 transition-all cursor-pointer group\" data-kid=\"28\">\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"29\">\n            <span class=\"font-tech text-xs text-slate-300 group-hover:text-white font-medium truncate pr-2\" data-kid=\"30\">Patient #82109 MRI</span>\n            <span class=\"text-[9px] font-mono text-slate-500\" data-kid=\"31\">2h ago</span>\n          </div>\n          <p class=\"text-[10px] text-slate-400 truncate\" data-kid=\"32\">Analyzing frontal lobe telemetry scans...</p>\n        </div>\n\n        \n        <div class=\"p-3 rounded bg-transparent border-l-2 border-transparent hover:border-slate-500 hover:bg-white/5 transition-all cursor-pointer group\" data-kid=\"33\">\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"34\">\n            <span class=\"font-tech text-xs text-slate-300 group-hover:text-white font-medium truncate pr-2\" data-kid=\"35\">Hypothalamus Anomaly</span>\n            <span class=\"text-[9px] font-mono text-slate-500\" data-kid=\"36\">1d ago</span>\n          </div>\n          <p class=\"text-[10px] text-slate-400 truncate\" data-kid=\"37\">Hormonal feedback loops investigation...</p>\n        </div>\n\n        \n        <div class=\"p-3 rounded bg-transparent border-l-2 border-transparent hover:border-slate-500 hover:bg-white/5 transition-all cursor-pointer group\" data-kid=\"38\">\n          <div class=\"flex justify-between items-start mb-1\" data-kid=\"39\">\n            <span class=\"font-tech text-xs text-slate-300 group-hover:text-white font-medium truncate pr-2\" data-kid=\"40\">Cytokine Storm Risk</span>\n            <span class=\"text-[9px] font-mono text-slate-500\" data-kid=\"41\">3d ago</span>\n          </div>\n          <p class=\"text-[10px] text-slate-400 truncate\" data-kid=\"42\">Evaluation of immune response markers...</p>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"cyber-panel bg-white/5 backdrop-blur-xl shadow-[inset_0_0_0_1px_rgba(255,255,255,0.12)] p-3 flex justify-between items-center relative shrink-0\" data-kid=\"43\">\n      <button class=\"flex items-center gap-2.5 text-xs font-tech tracking-wider text-slate-400 hover:text-red-400 transition-colors cursor-pointer pl-1 py-1\" data-kid=\"44\">\n        <i class=\"ti ti-logout text-base text-slate-500\" data-kid=\"45\"></i>\n        <span data-kid=\"46\">TERMINATE SESSION</span>\n      </button>\n      <button class=\"w-8 h-8 flex items-center justify-center rounded-lg bg-white/5 hover:bg-white/10 text-slate-300 hover:text-white border border-white/10 transition-all cursor-pointer\" data-kid=\"47\">\n        <i class=\"ti ti-settings text-base\" data-kid=\"48\"></i>\n      </button>\n    </div>\n  </aside>\n\n  \n  <main class=\"flex-1 h-full cyber-panel bg-white/5 backdrop-blur-xl shadow-[inset_0_0_0_1px_rgba(255,255,255,0.12)] flex flex-col overflow-hidden relative\" data-kid=\"49\">\n    \n    <header class=\"h-16 px-6 border-b border-white/10 flex items-center justify-between shrink-0 relative bg-slate-950/20\" data-kid=\"50\">\n      <div class=\"absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#1164B4]/20 to-transparent\" data-kid=\"51\"></div>\n      \n      <div class=\"flex items-center gap-2.5\" data-kid=\"52\">\n        <div class=\"w-8 h-8 rounded bg-[#1164B4]/20 border border-white/10 flex items-center justify-center text-slate-300\" data-kid=\"53\">\n          <i class=\"ti ti-medical-cross text-base\" data-kid=\"54\"></i>\n        </div>\n        <div data-kid=\"55\">\n          <h2 class=\"font-tech text-sm font-semibold tracking-wider text-white\" data-kid=\"56\">NEURAL DIAGNOSTIC CO-PILOT</h2>\n          <span class=\"text-[10px] font-mono text-slate-400\" data-kid=\"57\">SESSION ID: <span class=\"text-slate-300\" data-kid=\"58\">NDC-980-CYBER</span></span>\n        </div>\n      </div>\n\n      \n      <div class=\"flex items-center gap-2 px-3 py-1.5 rounded-full bg-emerald-500/10 border border-emerald-500/20\" data-kid=\"59\">\n        <span class=\"w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_8px_#34d399]\" data-kid=\"60\"></span>\n        <span class=\"font-tech text-xs font-semibold text-emerald-400 tracking-wider\" data-kid=\"61\">AI AGENT ONLINE</span>\n      </div>\n    </header>\n\n    \n    <div class=\"flex-1 flex flex-col justify-center items-center px-8 py-6 overflow-y-auto custom-scroll\" data-kid=\"62\">\n      \n      \n      <div class=\"w-full max-w-xl h-[260px] rounded-2xl overflow-hidden relative shadow-[inset_0_0_0_1px_rgba(255,255,255,0.1)] group\" data-kid=\"63\">\n        \n        <div class=\"absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-[#1164B4] via-[#0FFFFF]/60 to-[#1164B4] z-10\" data-kid=\"64\"></div>\n        \n        \n        <video class=\"w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-1000\" src=\"https://videos.pexels.com/video-files/35977110/15254859_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/35977110/pexels-photo-35977110.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" data-kid=\"65\">\n        </video>\n\n        \n        <div class=\"absolute inset-0 bg-gradient-to-t from-[#010B13]/90 via-[#010B13]/25 to-transparent z-2 pointer-events-none\" data-kid=\"66\"></div>\n        <div class=\"absolute inset-0 bg-radial-gradient from-transparent to-[#010B13]/50 z-2 pointer-events-none\" data-kid=\"67\"></div>\n\n        \n        <div class=\"absolute inset-0 flex flex-col items-center justify-center z-10\" data-kid=\"68\">\n          <div class=\"relative flex items-center justify-center\" data-kid=\"69\">\n            \n            <div class=\"absolute w-20 h-20 rounded-full bg-[#0FFFFF]/5 animate-ping duration-1000\" data-kid=\"70\"></div>\n            <div class=\"absolute w-16 h-16 rounded-full border border-white/20 bg-slate-950/60 backdrop-blur-md shadow-[0_0_20px_rgba(15,255,255,0.15)]\" data-kid=\"71\"></div>\n            \n            \n            <div class=\"relative w-14 h-14 rounded-full bg-gradient-to-br from-[#1164B4]/40 to-white/10 border border-white/20 flex items-center justify-center text-[#0FFFFF] text-xl shadow-[inset_0_0_12px_rgba(15,255,255,0.3)] neon-pulse\" data-kid=\"72\">\n              <i class=\"ti ti-stethoscope\" data-kid=\"73\"></i>\n            </div>\n          </div>\n          <div class=\"mt-4 px-3 py-1 rounded bg-slate-950/80 border border-white/10 backdrop-blur-sm\" data-kid=\"74\">\n            <span class=\"text-[10px] font-mono tracking-widest text-slate-300\" data-kid=\"75\">GENOME MODEL v4.12</span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"mt-8 w-full max-w-xl bg-white/5 p-4 rounded-xl shadow-[inset_0_0_0_1px_rgba(255,255,255,0.08)] flex items-start gap-4\" data-kid=\"76\">\n        <div class=\"w-10 h-10 rounded-lg bg-[#1164B4]/20 flex items-center justify-center text-[#0FFFFF] shrink-0 mt-0.5 border border-[#1164B4]/40\" data-kid=\"77\">\n          <i class=\"ti ti-terminal text-lg\" data-kid=\"78\"></i>\n        </div>\n        <div data-kid=\"79\">\n          <h3 class=\"font-tech text-base font-semibold text-white tracking-wide mb-1 flex items-center gap-2\" data-kid=\"80\">\n            Start a New Diagnostic Session\n            <span class=\"text-[9px] font-mono bg-emerald-500/10 text-emerald-400 px-1.5 py-0.5 rounded border border-emerald-500/20\" data-kid=\"81\">READY</span>\n          </h3>\n          <p class=\"text-xs text-slate-300 leading-relaxed font-sans mb-3\" data-kid=\"82\">\n            Query symptoms, cross-reference clinical research, or upload patient telemetry to obtain neural evidence-based answers.\n          </p>\n          \n          \n          <div class=\"flex flex-wrap gap-2\" data-kid=\"83\">\n            <button class=\"px-2.5 py-1 rounded bg-white/5 hover:bg-[#1164B4]/20 border border-white/10 hover:border-[#0FFFFF]/40 text-[10px] text-slate-300 hover:text-white transition-all duration-200 cursor-pointer font-mono flex items-center gap-1.5\" data-kid=\"84\">\n              <i class=\"ti ti-activity text-slate-400\" data-kid=\"85\"></i>\n              Arrhythmia check\n            </button>\n            <button class=\"px-2.5 py-1 rounded bg-white/5 hover:bg-[#1164B4]/20 border border-white/10 hover:border-[#0FFFFF]/40 text-[10px] text-slate-300 hover:text-white transition-all duration-200 cursor-pointer font-mono flex items-center gap-1.5\" data-kid=\"86\">\n              <i class=\"ti ti-dna text-slate-400\" data-kid=\"87\"></i>\n              Gene sequence\n            </button>\n            <button class=\"px-2.5 py-1 rounded bg-white/5 hover:bg-[#1164B4]/20 border border-white/10 hover:border-[#0FFFFF]/40 text-[10px] text-slate-300 hover:text-white transition-all duration-200 cursor-pointer font-mono flex items-center gap-1.5\" data-kid=\"88\">\n              <i class=\"ti ti-scan text-slate-400\" data-kid=\"89\"></i>\n              Extract MRI data\n            </button>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n    \n    <footer class=\"p-4 border-t border-white/10 shrink-0 bg-slate-950/40 relative\" data-kid=\"90\">\n      <div class=\"absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[#1164B4]/20 to-transparent\" data-kid=\"91\"></div>\n      \n      \n      <div class=\"flex items-center gap-3 bg-white/5 border border-white/10 focus-within:border-[#0FFFFF]/50 rounded-xl p-2 px-3 backdrop-blur-xl transition-all duration-300 group shadow-[inset_0_1px_1px_rgba(255,255,255,0.05)]\" data-kid=\"92\">\n        \n        <button class=\"w-10 h-10 rounded-lg hover:bg-white/5 flex items-center justify-center text-slate-400 hover:text-white transition-colors cursor-pointer\" data-kid=\"93\">\n          <i class=\"ti ti-paperclip text-lg\" data-kid=\"94\"></i>\n        </button>\n        \n        \n        <input type=\"text\" placeholder=\"Type your medical question...\" class=\"flex-1 bg-transparent border-hidden outline-hidden text-sm text-white placeholder-slate-400 font-sans py-2\" data-kid=\"95\">\n\n        \n        <div class=\"hidden sm:flex items-center gap-1.5 px-2 py-1 rounded bg-slate-950/60 border border-white/15 text-[9px] font-mono text-slate-400\" data-kid=\"96\">\n          <span class=\"w-1.5 h-1.5 rounded-full bg-[#1164B4]\" data-kid=\"97\"></span>\n          <span data-kid=\"98\">HIPAA SECURE</span>\n        </div>\n\n        \n        <button class=\"w-10 h-10 rounded-lg bg-[#0FFFFF] hover:shadow-[0_0_15px_#0FFFFF] text-slate-950 flex items-center justify-center transition-all duration-300 transform active:scale-95 cursor-pointer\" data-kid=\"99\">\n          <i class=\"ti ti-arrow-right text-base font-bold\" data-kid=\"100\"></i>\n        </button>\n      </div>\n      \n      \n      <p class=\"text-[10px] text-slate-400 text-center mt-2 font-mono tracking-wider\" data-kid=\"101\">\n        DISCLAIMER: DEMO INTELLIGENCE TERMINAL ONLY. DO NOT SUBSTITUTE FOR PROFESSIONAL MEDICAL JUDGEMENT.\n      </p>\n    </footer>\n  </main>\n\n  \n  <aside class=\"w-[300px] h-full flex flex-col gap-4 shrink-0\" data-kid=\"102\">\n    \n    <div class=\"cyber-panel bg-white/5 backdrop-blur-xl shadow-[inset_0_0_0_1px_rgba(255,255,255,0.12)] p-4 flex flex-col flex-1 min-h-0 relative\" data-kid=\"103\">\n      <div class=\"absolute top-0 right-0 w-[2px] h-12 bg-[#0FFFFF] shadow-[0_0_8px_#0FFFFF]\" data-kid=\"104\"></div>\n      \n      <div class=\"flex items-center justify-between border-b border-white/10 pb-2.5 mb-4\" data-kid=\"105\">\n        <div class=\"flex items-center gap-2\" data-kid=\"106\">\n          <i class=\"ti ti-scan-eye text-[#0FFFFF] text-base\" data-kid=\"107\"></i>\n          <h3 class=\"font-tech text-xs font-semibold tracking-wider text-white\" data-kid=\"108\">3D BIO-SYSTEM RENDER</h3>\n        </div>\n        <span class=\"text-[9px] font-mono px-1.5 py-0.5 rounded bg-white/10 text-white border border-white/10\" data-kid=\"109\">LIVE</span>\n      </div>\n\n      \n      <div class=\"flex-1 rounded-xl bg-slate-950/50 border border-white/5 flex flex-col items-center justify-center relative overflow-hidden group\" data-kid=\"110\">\n        \n        <div class=\"absolute inset-0 bg-[linear-gradient(rgba(15,255,255,0.02)_50%,transparent_50%)] bg-[length:100%_4px] pointer-events-none\" data-kid=\"111\"></div>\n        <div class=\"absolute inset-0 bg-radial-gradient from-transparent to-slate-950/80 pointer-events-none\" data-kid=\"112\"></div>\n\n        \n        <div class=\"relative w-44 h-44 flex items-center justify-center\" data-kid=\"113\">\n          \n          <div class=\"absolute inset-0 border border-dashed border-white/10 rounded-full animate-spin duration-[10000ms]\" data-kid=\"114\"></div>\n          <div class=\"absolute inset-2 border border-dotted border-[#1164B4]/20 rounded-full animate-reverse-spin duration-[15000ms]\" style=\"animation-direction: reverse;\" data-kid=\"115\"></div>\n          \n          \n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/heart-organ.svg\" class=\"w-24 h-24 relative z-10 transition-transform duration-500 group-hover:scale-105\" style=\"filter: drop-shadow(0 0 15px rgba(15,255,255,0.5)) invert(58%) sepia(87%) saturate(3025%) hue-rotate(143deg) brightness(101%) contrast(101%);\" alt=\"Anatomical Heart Render\" decoding=\"async\" loading=\"lazy\" data-kid=\"116\">\n          \n          \n          <div class=\"absolute top-0 left-0 text-[8px] font-mono text-slate-500\" data-kid=\"117\">SYS_H_32.09</div>\n          <div class=\"absolute bottom-0 right-0 text-[8px] font-mono text-slate-500\" data-kid=\"118\">SYS_V_81.44</div>\n        </div>\n\n        <div class=\"w-full px-4 py-2 bg-slate-950/70 border-t border-white/5 z-10 flex justify-between items-center text-[10px] font-mono text-slate-400\" data-kid=\"119\">\n          <span data-kid=\"120\">STRUCTURAL FOCUS</span>\n          <span class=\"text-white font-medium\" data-kid=\"121\">LEFT VENTRICLE</span>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"cyber-panel bg-white/5 backdrop-blur-xl shadow-[inset_0_0_0_1px_rgba(255,255,255,0.12)] p-4 flex flex-col h-[280px] relative\" data-kid=\"122\">\n      <div class=\"absolute bottom-0 right-0 w-8 h-[2px] bg-[#0FFFFF] shadow-[0_0_8px_#0FFFFF]\" data-kid=\"123\"></div>\n      \n      <div class=\"flex items-center justify-between border-b border-white/10 pb-2 mb-3\" data-kid=\"124\">\n        <div class=\"flex items-center gap-2\" data-kid=\"125\">\n          <i class=\"ti ti-timeline text-[#1164B4] text-base\" data-kid=\"126\"></i>\n          <h3 class=\"font-tech text-xs font-semibold tracking-wider text-white\" data-kid=\"127\">PATIENT TELEMETRY & VITALS</h3>\n        </div>\n        <i class=\"ti ti-activity text-emerald-400 text-sm animate-pulse\" data-kid=\"128\