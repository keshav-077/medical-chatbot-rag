    "var_9bd8b232ed18": {
      "type": "variant",
      "label": "Variant B: Bioluminescent Aurora (Light)",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 5520,
        "y": 0,
        "w": 1280,
        "h": 800
