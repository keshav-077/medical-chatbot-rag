# ============================================================
# Medical Chatbot RAG v2.0.0 — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
# All API keys are free tier — no credit card required.
# ============================================================

# === REQUIRED ===

# Pinecone: Vector database for document search
# Get key: https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key

# OpenRouter: Primary LLM provider (gpt-oss-120b:free)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Flask: Secret key for session encryption
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-string-in-production

# === EMBEDDINGS (at least one required) ===

# Jina AI: Primary embedding provider (768 dims, 10M free tokens)
# Get key: https://jina.ai/ → API Dashboard
JINA_API_KEY=your-jina-api-key

# HuggingFace: Backup embedding provider (768 dims, free)
# Get key: https://huggingface.co/settings/tokens
# Enable "Make calls to inference providers" permission
HUGGINGFACE_API_KEY=your-huggingface-api-key

# === LLM FALLBACK (optional) ===

# Groq: Backup LLM provider (gpt-oss-120b, 30 req/min free)
# Get key: https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# === DATABASE (production/Vercel only) ===

# Neon PostgreSQL: Serverless Postgres
# Get connection string: https://console.neon.tech
# IMPORTANT: Use the -pooler endpoint for serverless
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# === DEPLOYMENT ===

# Environment: 'development' (SQLite) or 'production' (PostgreSQL)
FLASK_ENV=development

# Your deployed URL (used in OpenRouter HTTP-Referer header)
APP_URL=http://localhost:8080

# === RATE LIMITING (production, optional) ===

# In-memory rate limiting works for dev but NOT for Vercel serverless.
# For production, use Upstash Redis (free: 10K commands/day):
# https://upstash.com → Create Redis database → Copy REST URL
# RATELIMIT_STORAGE_URI=redis://default:xxx@xxx.upstash.io:6379