x-col\" data-kid=\"145\">\n            <span class=\"text-[9px] text-slate-400 font-mono\" data-kid=\"146\">BLOOD PRESS.</span>\n            <span class=\"font-tech text-sm font-bold text-white mt-1\" data-kid=\"147\">120/80</span>\n          </div>\n        </div>\n\n        \n        <div class=\"flex items-center justify-between bg-white/5 p-2 rounded border border-white/5\" data-kid=\"148\">\n          <div class=\"flex items-center gap-2\" data-kid=\"149\">\n            <span class=\"w-1.5 h-1.5 rounded-full bg-slate-500\" data-kid=\"150\"></span>\n            <span class=\"text-[10px] text-slate-400 font-mono\" data-kid=\"151\">GENOME SYNC</span>\n          </div>\n          <div class=\"text-right\" data-kid=\"152\">\n            <span class=\"font-tech text-xs font-bold text-white\" data-kid=\"153\">99.12%</span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </aside>\n</div>",
