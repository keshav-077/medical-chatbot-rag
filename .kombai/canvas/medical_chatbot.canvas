    "var_19d5c3dbdfb5": {
      "type": "variant",
      "label": "Variant 3: Futuristic HUD Medical Chatbot",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 2760,
        "y": 0,
        "w": 1280,
        "h": 800
