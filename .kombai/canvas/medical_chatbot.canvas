      "html": "\n<div class=\"w-full h-[820px] relative overflow-hidden bg-gradient-to-br from-[#FFF5EE] via-[#FFF0EC] to-[#FFE4E1] font-['Nunito_Sans'] text-[#4A5D23] select-none flex flex-col justify-between\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Quicksand:wght@500;600;700&family=Nunito+Sans:wght@400;600;700&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css');\n\n    .font-heading {\n      font-family: 'Quicksand', sans-serif;\n    }\n\n    /* Claymorphism */\n    .clay-card {\n      background: rgba(255, 255, 255, 0.9);\n      backdrop-filter: blur(16px);\n      border: 2.5px solid rgba(255, 255, 255, 0.95);\n      box-shadow: \n        0 16px 36px -8px rgba(74, 93, 35, 0.12),\n        inset 2px 2px 4px rgba(255, 255, 255, 1),\n        inset -4px -4px 10px rgba(74, 93, 35, 0.05);\n    }\n\n    .clay-pill-active {\n      background: #E3256B;\n      color: #FFFFFF !important;\n      box-shadow: \n        0 8px 20px -6px rgba(227, 37, 107, 0.45),\n        inset 1px 1px 3px rgba(255, 255, 255, 0.4);\n    }\n\n    .clay-input {\n      background: rgba(255, 255, 255, 0.65);\n      border: 2px solid rgba(74, 93, 35, 0.1);\n      box-shadow: \n        inset 2px 2px 5px rgba(74, 93, 35, 0.05),\n        0 4px 12px rgba(255, 255, 255, 0.5);\n      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n    }\n    .clay-input:focus {\n      outline: none;\n      border-color: #E3256B;\n      box-shadow: \n        0 0 0 4px rgba(227, 37, 107, 0.15),\n        inset 1px 1px 3px rgba(227, 37, 107, 0.1);\n    }\n\n    /* Neomorphism Raised */\n    .neomorph-raised-card {\n      background: #FFE6E1;\n      box-shadow: \n        8px 8px 20px rgba(74, 93, 35, 0.1),\n        -8px -8px 20px rgba(255, 255, 255, 0.95);\n      border: 1.5px solid rgba(255, 255, 255, 0.7);\n    }\n\n    /* Custom Razzmatazz colored-shadows */\n    .razz-shadow {\n      box-shadow: 0 10px 24px -6px rgba(227, 37, 107, 0.3);\n    }\n\n    /* Animations */\n    @keyframes drift1 {\n      0% { transform: translate(0px, 0px) scale(1); }\n      50% { transform: translate(40px, -60px) scale(1.15); }\n      100% { transform: translate(0px, 0px) scale(1); }\n    }\n    @keyframes drift2 {\n      0% { transform: translate(0px, 0px) scale(1.1); }\n      50% { transform: translate(-50px, 50px) scale(0.9); }\n      100% { transform: translate(0px, 0px) scale(1.1); }\n    }\n    @keyframes slideUp {\n      from { transform: translateY(100%); opacity: 0; }\n      to { transform: translateY(0); opacity: 1; }\n    }\n\n    .animate-drift-1 {\n      animation: drift1 18s ease-in-out infinite alternate;\n    }\n    .animate-drift-2 {\n      animation: drift2 22s ease-in-out infinite alternate;\n    }\n    .animate-slide-up {\n      animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;\n    }\n\n    /* Custom Scrollbar for inner container */\n    .custom-scroll::-webkit-scrollbar {\n      width: 6px;\n    }\n    .custom-scroll::-webkit-scrollbar-track {\n      background: rgba(74, 93, 35, 0.03);\n      border-radius: 99px;\n    }\n    .custom-scroll::-webkit-scrollbar-thumb {\n      background: rgba(74, 93, 35, 0.15);\n      border-radius: 99px;\n    }\n    .custom-scroll::-webkit-scrollbar-thumb:hover {\n      background: rgba(74, 93, 35, 0.25);\n    }\n  </style>\n\n  \n  <div class=\"absolute inset-0 overflow-hidden pointer-events-none z-0\" data-kid=\"2\">\n    <div class=\"absolute -top-20 -left-20 w-[450px] h-[450px] rounded-[55%_45%_50%_50%] bg-[#FFD1C7] opacity-40 blur-3xl animate-drift-1\" data-kid=\"3\"></div>\n    <div class=\"absolute -bottom-20 -right-20 w-[500px] h-[500px] rounded-[48%_52%_45%_55%] bg-[#FFE5B4] opacity-35 blur-3xl animate-drift-2\" data-kid=\"4\"></div>\n    <div class=\"absolute top-[40%] left-[30%] w-[350px] h-[350px] rounded-[60%_40%_30%_70%/60%_30%_70%_40%] bg-[#FFDEE9] opacity-30 blur-3xl animate-drift-1\" data-kid=\"5\"></div>\n  </div>\n\n  \n  <div class=\"w-full h-full relative z-10 flex flex-col p-5 max-w-[1280px] mx-auto overflow-hidden\" data-kid=\"6\">\n    \n    \n    <header class=\"flex items-center justify-between h-[65px] px-4 mb-3\" data-kid=\"7\">\n      \n      <div class=\"flex items-center gap-3\" data-kid=\"8\">\n        <div class=\"w-11 h-11 rounded-[60%_40%_30%_70%/60%_30%_70%_40%] bg-[#E3256B] flex items-center justify-center text-white shadow-lg shadow-[#E3256B]/20\" data-kid=\"9\">\n          <i class=\"ti ti-heart-handshake text-2xl\" data-kid=\"10\"></i>\n        </div>\n        <div data-kid=\"11\">\n          <h1 class=\"font-heading font-bold text-lg tracking-tight text-[#4A5D23] leading-none\" data-kid=\"12\">bloom</h1>\n          <span class=\"text-xs text-[#4A5D23]/60 font-semibold tracking-wide uppercase\" data-kid=\"13\">Organic Care</span>\n        </div>\n      </div>\n\n      \n      <nav class=\"clay-card rounded-full p-1.5 flex gap-1 z-30\" data-kid=\"14\">\n        <button id=\"tab-chat\" onclick=\"switchView('chat')\" class=\"px-5 py-2 rounded-full text-sm font-heading font-semibold transition-all duration-300 clay-pill-active cursor-pointer\" data-kid=\"15\">\n          <i class=\"ti ti-brand-telegram text-base mr-1.5 align-middle\" data-kid=\"16\"></i>Empathic Chatbot\n        </button>\n        <button id=\"tab-login\" onclick=\"switchView('login')\" class=\"px-5 py-2 rounded-full text-sm font-heading font-semibold text-[#4A5D23]/70 hover:text-[#4A5D23] transition-all duration-300 cursor-pointer\" data-kid=\"17\">\n          <i class=\"ti ti-lock-open text-base mr-1.5 align-middle\" data-kid=\"18\"></i>Warm Sign In\n        </button>\n        <button id=\"tab-signup\" onclick=\"switchView('signup')\" class=\"px-5 py-2 rounded-full text-sm font-heading font-semibold text-[#4A5D23]/70 hover:text-[#4A5D23] transition-all duration-300 cursor-pointer\" data-kid=\"19\">\n          <i class=\"ti ti-user-plus text-base mr-1.5 align-middle\" data-kid=\"20\"></i>Friendly Sign Up\n        </button>\n      </nav>\n\n      \n      <div class=\"flex items-center gap-3 clay-card px-4 py-2 rounded-full\" data-kid=\"21\">\n        <div class=\"relative\" data-kid=\"22\">\n          <img src=\"https://i.pravatar.cc/100?u=kesav\" alt=\"User Avatar\" class=\"w-9 h-9 rounded-[40%_60%_70%_30%/40%_50%_60%_50%] border-2 border-[#E3256B]/30 object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"23\">\n          <div class=\"absolute bottom-0 right-0 w-3 h-3 bg-emerald-500 rounded-full border-2 border-white\" data-kid=\"24\"></div>\n        </div>\n        <div class=\"text-left hidden md:block\" data-kid=\"25\">\n          <p class=\"text-xs font-heading font-bold leading-none text-[#4A5D23]\" data-kid=\"26\">Kesavardhan M.</p>\n          <span class=\"text-[10px] text-emerald-600 font-bold uppercase tracking-wider\" data-kid=\"27\">Premium Care</span>\n        </div>\n      </div>\n    </header>\n\n    \n    <div id=\"content-portal\" class=\"flex-1 relative overflow-hidden flex gap-4\" data-kid=\"28\">\n      \n      \n      <div id=\"view-chat\" class=\"w-full h-full flex gap-5 transition-all duration-300\" data-kid=\"29\">\n        \n        \n        <div class=\"w-[35%] h-full flex flex-col gap-4 overflow-y-auto custom-scroll pr-2 justify-between\" data-kid=\"30\">\n          \n          \n          <div class=\"neomorph-raised-card p-5 rounded-[24px] flex flex-col justify-between relative overflow-hidden group min-h-[190px]\" data-kid=\"31\">\n            <div class=\"relative z-10\" data-kid=\"32\">\n              <span class=\"bg-[#E3256B]/15 text-[#E3256B] text-xs font-extrabold px-3 py-1 rounded-full uppercase tracking-wider\" data-kid=\"33\">Aura Wellness</span>\n              <h2 class=\"text-2xl font-heading font-extrabold text-[#4A5D23] mt-3.5 leading-snug\" data-kid=\"34\">Hello, Kesavardhan</h2>\n              <p class=\"text-sm text-[#4A5D23] mt-1.5 font-medium\" data-kid=\"35\">Let's check in on your respiratory & overall state today.</p>\n            </div>\n            \n            <div class=\"flex items-center justify-between mt-5 relative z-10\" data-kid=\"36\">\n              <div class=\"w-14 h-14 rounded-[60%_40%_30%_70%/60%_30%_70%_40%] bg-white/95 flex items-center justify-center border border-[#E3256B]/35 shadow-sm\" data-kid=\"37\">\n                <i class=\"ti ti-sparkles text-2xl text-[#E3256B]\" data-kid=\"38\"></i>\n              </div>\n              <div class=\"text-right\" data-kid=\"39\">\n                <p class=\"text-sm font-extrabold text-[#E3256B] bg-white/80 px-2.5 py-1 rounded-full border border-[#E3256B]/10 inline-block shadow-xs\" data-kid=\"40\">98% Sleep Score</p>\n              </div>\n            </div>\n\n            \n            <div class=\"absolute right-[-10px] bottom-[-10px] w-32 h-32 opacity-75 rotate-12 transition-transform group-hover:rotate-45 duration-700 pointer-events-none\" data-kid=\"41\">\n              <img src=\"https://images.unsplash.com/photo-1646736722278-2eed3d2c2159?auto=format&w=250&q=80&fit=crop\" alt=\"Pill graphic\" class=\"w-full h-full object-contain\" decoding=\"async\" loading=\"lazy\" data-kid=\"42\">\n            </div>\n          </div>\n\n          \n          <div class=\"grid grid-cols-2 gap-4\" data-kid=\"43\">\n            \n            \n            <div onclick=\"selectTopic('symptom')\" class=\"clay-card p-5 rounded-[22px] cursor-pointer hover:border-[#E3256B]/40 hover:scale-[1.02] transition-all duration-300 text-left\" data-kid=\"44\">\n              <div class=\"w-10 h-10 rounded-[30%_70%_70%_30%] bg-pink-100 flex items-center justify-center mb-3 border border-[#E3256B]/20\" data-kid=\"45\">\n                <i class=\"ti ti-activity-heartbeat text-xl text-[#E3256B]\" data-kid=\"46\"></i>\n              </div>\n              <h3 class=\"text-sm font-heading font-extrabold text-[#4A5D23]\" data-kid=\"47\">Symptom Scan</h3>\n              <p class=\"text-xs text-[#4A5D23] font-medium mt-1\" data-kid=\"48\">Check persistent mild coughs</p>\n            </div>\n\n            \n            <div onclick=\"selectTopic('medication')\" class=\"clay-card p-5 rounded-[22px] cursor-pointer hover:border-[#E3256B]/40 hover:scale-[1.02] transition-all duration-300 text-left\" data-kid=\"49\">\n              <div class=\"w-10 h-10 rounded-[70%_30%_30%_70%] bg-emerald-100 flex items-center justify-center mb-3 border border-emerald-500/20\" data-kid=\"50\">\n                <i class=\"ti ti-pill text-xl text-emerald-700\" data-kid=\"51\"></i>\n              </div>\n              <h3 class=\"text-sm font-heading font-extrabold text-[#4A5D23]\" data-kid=\"52\">My Meds</h3>\n              <p class=\"text-xs text-emerald-800 font-extrabold mt-1\" data-kid=\"53\">2 remaining today</p>\n            </div>\n\n          </div>\n\n          \n          <div onclick=\"selectTopic('lungs')\" class=\"clay-card p-5 rounded-[24px] cursor-pointer hover:border-[#E3256B]/50 transition-all duration-300 relative overflow-hidden flex flex-col justify-between h-[210px] group\" data-kid=\"54\">\n            <div class=\"relative z-10 max-w-[60%]\" data-kid=\"55\">\n              <div class=\"flex items-center gap-2\" data-kid=\"56\">\n                <span class=\"w-2.5 h-2.5 rounded-full bg-[#E3256B] animate-pulse\" data-kid=\"57\"></span>\n                <span class=\"text-xs font-extrabold text-[#4A5D23] uppercase tracking-wider\" data-kid=\"58\">Interactive Insight</span>\n              </div>\n              <h3 class=\"text-lg font-heading font-extrabold text-[#4A5D23] mt-2.5 leading-snug\" data-kid=\"59\">Deep Lung Health</h3>\n              <p class=\"text-xs text-[#4A5D23] font-medium mt-1\" data-kid=\"60\">Visualize and discuss alveolar response.</p>\n            </div>\n            \n            <div class=\"relative z-10 flex justify-between items-center mt-3\" data-kid=\"61\">\n              <span class=\"text-xs bg-[#E3256B] hover:bg-[#E3256B]/90 text-white px-3.5 py-1.5 rounded-full font-bold shadow-md transition-all group-hover:scale-105\" data-kid=\"62\">Explore Art</span>\n              <span class=\"text-xs text-[#4A5D23] font-extrabold bg-white/80 px-2 py-0.5 rounded-md\" data-kid=\"63\"><i class=\"ti ti-eye mr-1\" data-kid=\"64\"></i>3.2k</span>\n            </div>\n\n            \n            <div class=\"absolute right-0 top-0 bottom-0 w-[45%] opacity-85 transition-all duration-500 scale-100 group-hover:scale-110 pointer-events-none\" data-kid=\"65\">\n              <img src=\"https://images.unsplash.com/photo-1715529407875-7f1c7176d074?auto=format&w=250&q=80&fit=crop\" alt=\"Lung artwork\" class=\"w-full h-full object-cover rounded-l-[32px] border-l border-white/40\" decoding=\"async\" loading=\"lazy\" data-kid=\"66\">\n            </div>\n          </div>\n\n        </div>\n\n        \n        <div class=\"w-[65%] h-full flex flex-col clay-card rounded-[32px] overflow-hidden relative\" data-kid=\"67\">\n          \n          \n          <div class=\"bg-gradient-to-r from-[#FFE4E1] to-[#FFF5EE] p-4 flex items-center justify-between border-b border-white/60 relative\" data-kid=\"68\">\n            <div class=\"flex items-center gap-3\" data-kid=\"69\">\n              <div class=\"w-10 h-10 rounded-full bg-white flex items-center justify-center text-[#E3256B] shadow-sm\" data-kid=\"70\">\n                <i class=\"ti ti-robot text-xl\" data-kid=\"71\"></i>\n              </div>\n              <div data-kid=\"72\">\n                <div class=\"flex items-center gap-1.5\" data-kid=\"73\">\n                  <h3 class=\"font-heading font-bold text-sm text-[#4A5D23]\" data-kid=\"74\">Dr. Flora</h3>\n                  <span class=\"w-2 h-2 rounded-full bg-emerald-500\" data-kid=\"75\"></span>\n                </div>\n                <p class=\"text-xs text-[#4A5D23]/60\" data-kid=\"76\">Empathic AI companion</p>\n              </div>\n            </div>\n            \n            \n            <div class=\"flex items-center gap-2\" data-kid=\"77\">\n              <span class=\"text-xs bg-[#FFF5EE] px-3 py-1 rounded-full text-[#4A5D23]/80 border border-white/85 font-semibold\" data-kid=\"78\">Voice Mode</span>\n              <button class=\"w-8 h-8 rounded-full bg-white hover:bg-[#FFE4E1] flex items-center justify-center text-[#4A5D23]/70 transition-colors cursor-pointer\" data-kid=\"79\">\n                <i class=\"ti ti-settings text-base\" data-kid=\"80\"></i>\n              </button>\n            </div>\n          </div>\n\n          \n          <div id=\"chat-scroller\" class=\"flex-1 overflow-y-auto p-5 space-y-4 custom-scroll\" data-kid=\"81\">\n            \n            \n            <div class=\"flex items-start gap-3\" data-kid=\"82\">\n              <div class=\"w-10 h-10 rounded-[60%_40%_30%_70%/60%_30%_70%_40%] bg-[#FFEBE7] flex items-center justify-center text-[#E3256B] shrink-0 mt-1 border border-[#E3256B]/20\" data-kid=\"83\">\n                <i class=\"ti ti-seedling text-lg\" data-kid=\"84\"></i>\n              </div>\n              <div class=\"max-w-[80%] rounded-[2px_24px_24px_24px] bg-white p-5 shadow-sm border border-white/80\" data-kid=\"85\">\n                <p class=\"text-sm leading-relaxed text-[#4A5D23] font-medium\" data-kid=\"86\">\n                  Greetings, Kesavardhan. I'm Dr. Flora, your empathic health assistant. How is your breathing today? I can help you evaluate respiratory patterns, look over clinical illustrations, or organize your logs.\n                </p>\n                \n                <div class=\"flex flex-wrap gap-2 mt-4\" data-kid=\"87\">\n                  <button onclick=\"selectTopic('lungs')\" class=\"text-xs bg-[#FFE4E1] hover:bg-[#FFD2CC] text-[#E3256B] border border-[#E3256B]/20 px-3.5 py-2 rounded-full font-heading font-extrabold transition-all cursor-pointer shadow-xs\" data-kid=\"88\">\n                    <i class=\"ti ti-lungs text-sm mr-1.5 align-middle\" data-kid=\"89\"></i>Analyze Lung Health\n                  </button>\n                  <button onclick=\"selectTopic('symptom')\" class=\"text-xs bg-[#FFF5EE] hover:bg-[#FFEBE7] text-[#425021] border border-[#4A5D23]/30 px-3.5 py-2 rounded-full font-heading font-extrabold transition-all cursor-pointer shadow-xs\" data-kid=\"90\">\n                    <i class=\"ti ti-heart-rate-monitor text-sm mr-1.5 align-middle\" data-kid=\"91\"></i>Symptom Scan\n                  </button>\n                  <button onclick=\"selectTopic('medication')\" class=\"text-xs bg-[#FFF5EE] hover:bg-[#FFEBE7] text-[#425021] border border-[#4A5D23]/30 px-3.5 py-2 rounded-full font-heading font-extrabold transition-all cursor-pointer shadow-xs\" data-kid=\"92\">\n                    <i class=\"ti ti-hourglass-low text-sm mr-1.5 align-middle\" data-kid=\"93\"></i>Log My Meds\n                  </button>\n                </div>\n              </div>\n            </div>\n\n            \n            <div id=\"dynamic-messages-hook\" class=\"space-y-4\" data-kid=\"94\"></div>\n\n          </div>\n\n          \n          <div class=\"p-5 bg-white/60 border-t border-white/60\" data-kid=\"95\">\n            <form onsubmit=\"handleSend(event)\" class=\"flex gap-3 relative\" data-kid=\"96\">\n              <input id=\"chat-input\" type=\"text\" placeholder=\"Type gently here... Ask about breathing or symptoms...\" class=\"flex-1 clay-input rounded-full py-4 px-6 text-sm text-[#4A5D23] font-semibold placeholder:text-[#4A5D23]/70\" data-kid=\"97\">\n              \n              <button type=\"submit\" class=\"w-14 h-14 rounded-full bg-[#E3256B] text-white flex items-center justify-center hover:scale-105 active:scale-95 transition-all duration-200 cursor-pointer razz-shadow shrink-0\" data-kid=\"98\">\n                <i class=\"ti ti-brand-telegram text-2xl\" data-kid=\"99\"></i>\n              </button>\n            </form>\n            <p class=\"text-center text-xs text-[#4A5D23]/80 mt-4 font-bold\" data-kid=\"100\">\n              <i class=\"ti ti-info-circle mr-1 align-middle text-sm text-[#E3256B]\" data-kid=\"101\"></i>For diagnostic emergencies, please consult a real-world primary clinic.\n            </p>\n          </div>\n\n        </div>\n\n      </div>\n\n      \n      <div id=\"view-login\" class=\"hidden w-full h-full flex items-center justify-center\" data-kid=\"102\">\n        <div class=\"w-full max-w-md h-[550px] relative rounded-[32px] overflow-hidden clay-card flex flex-col justify-end animate-slide-up\" data-kid=\"103\">\n          \n          <div class=\"absolute inset-0 bg-gradient-to-br from-[#FFE4E1] to-[#FFF5EE] p-8 flex flex-col justify-start\" data-kid=\"104\">\n            <div class=\"w-12 h-12 rounded-full bg-white flex items-center justify-center text-[#E3256B] mb-4\" data-kid=\"105\">\n              <i class=\"ti ti-keytext text-2xl\" data-kid=\"106\"></i>\n            </div>\n            <h2 class=\"text-3xl font-heading font-bold text-[#4A5D23] leading-none\" data-kid=\"107\">Welcome Back</h2>\n            <p class=\"text-sm text-[#4A5D23]/70 mt-2\" data-kid=\"108\">Sign in to check your organic medical records.</p>\n          </div>\n\n          \n          <div class=\"relative bg-white/95 rounded-t-[36px] p-6 shadow-2xl border-t border-white flex flex-col gap-4 z-10\" data-kid=\"109\">\n            \n            <div class=\"flex items-center gap-3 bg-emerald-50 border border-emerald-200/50 p-3 rounded-2xl text-xs text-emerald-800 font-medium\" data-kid=\"110\">\n              <i class=\"ti ti-circle-check-filled text-lg text-emerald-600 shrink-0\" data-kid=\"111\"></i>\n              <span data-kid=\"112\">Success! Your warm bloom profile is ready. Please log in below.</span>\n            </div>\n\n            <div data-kid=\"113\">\n              <label class=\"block text-xs font-heading font-bold text-[#4A5D23] mb-1.5 ml-1\" data-kid=\"114\">Email Address</label>\n              <input type=\"email\" value=\"kesavardhan775@gmail.com\" class=\"w-full clay-input rounded-[18px] py-2.5 px-4 text-sm font-medium text-[#4A5D23]\" data-kid=\"115\">\n            </div>\n\n            <div data-kid=\"116\">\n              <div class=\"flex justify-between mb-1.5 ml-1\" data-kid=\"117\">\n                <label class=\"text-xs font-heading font-bold text-[#4A5D23]\" data-kid=\"118\">Password</label>\n                <a href=\"#\" class=\"text-xs text-[#E3256B] font-bold hover:underline\" data-kid=\"119\">Forgot?</a>\n              </div>\n              <input type=\"password\" value=\"Realmegt3t@\" class=\"w-full clay-input rounded-[18px] py-2.5 px-4 text-sm font-medium text-[#4A5D23]\" data-kid=\"120\">\n            </div>\n\n            <div class=\"flex items-center gap-2 ml-1\" data-kid=\"121\">\n              <input type=\"checkbox\" id=\"remember\" checked class=\"w-4 h-4 rounded accent-[#E3256B]\" data-kid=\"122\">\n              <label for=\"remember\" class=\"text-xs font-semibold text-[#4A5D23]/70\" data-kid=\"123\">Remember my secure session</label>\n            </div>\n\n            <button onclick=\"simulateAuthSuccess('login')\" class=\"w-full bg-[#E3256B] hover:bg-[#E3256B]/90 text-white font-heading font-bold py-3.5 rounded-[18px] transition-all razz-shadow cursor-pointer text-sm\" data-kid=\"124\">\n              Sign In Securely\n            </button>\n\n            <p class=\"text-center text-xs text-[#4A5D23]/60 font-semibold mt-1\" data-kid=\"125\">\n              Don't have an organic account? \n              <button onclick=\"switchView('signup')\" class=\"text-[#E3256B] font-bold hover:underline cursor-pointer\" data-kid=\"126\">Friendly Sign Up</button>\n            </p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div id=\"view-signup\" class=\"hidden w-full h-full flex items-center justify-center\" data-kid=\"127\">\n        <div class=\"w-full max-w-md h-[550px] relative rounded-[32px] overflow-hidden clay-card flex flex-col justify-end animate-slide-up\" data-kid=\"128\">\n          \n          <div class=\"absolute inset-0 bg-gradient-to-br from-[#FFE4E1] to-[#FFF5EE] p-8 flex flex-col justify-start\" data-kid=\"129\">\n            <div class=\"w-12 h-12 rounded-full bg-white flex items-center justify-center text-[#E3256B] mb-4\" data-kid=\"130\">\n              <i class=\"ti ti-user-plus text-2xl\" data-kid=\"131\"></i>\n            </div>\n            <h2 class=\"text-3xl font-heading font-bold text-[#4A5D23] leading-none\" data-kid=\"132\">Create Account</h2>\n            <p class=\"text-sm text-[#4A5D23]/70 mt-2\" data-kid=\"133\">Join Bloom chatbot for warm & caring health insights.</p>\n          </div>\n\n          \n          <div class=\"relative bg-white/95 rounded-t-[36px] p-6 shadow-2xl border-t border-white flex flex-col gap-4 z-10\" data-kid=\"134\">\n            <div data-kid=\"135\">\n              <label class=\"block text-xs font-heading font-bold text-[#4A5D23] mb-1.5 ml-1\" data-kid=\"136\">Full Name</label>\n              <input type=\"text\" value=\"KESAVARDHAN MAKIREDDI\" class=\"w-full clay-input rounded-[18px] py-2.5 px-4 text-sm font-medium text-[#4A5D23]\" data-kid=\"137\">\n            </div>\n\n            <div data-kid=\"138\">\n              <label class=\"block text-xs font-heading font-bold text-[#4A5D23] mb-1.5 ml-1\" data-kid=\"139\">Email Address</label>\n              <input type=\"email\" value=\"kesavardhan775@gmail.com\" class=\"w-full clay-input rounded-[18px] py-2.5 px-4 text-sm font-medium text-[#4A5D23]\" data-kid=\"140\">\n            </div>\n\n            <div class=\"grid grid-cols-2 gap-3\" data-kid=\"141\">\n              <div data-kid=\"142\">\n                <label class=\"block text-xs font-heading font-bold text-[#4A5D23] mb-1.5 ml-1\" data-kid=\"143\">Password</label>\n                <input type=\"password\" value=\"••••••••••••\" class=\"w-full clay-input rounded-[18px] py-2.5 px-4 text-sm font-medium text-[#4A5D23]\" data-kid=\"144\">\n              </div>\n              <div data-kid=\"145\">\n                <label class=\"block text-xs font-heading font-bold text-[#4A5D23] mb-1.5 ml-1\" data-kid=\"146\">Confirm Password</label>\n                <input type=\"password\" value=\"••••••••••••\" class=\"w-full clay-input rounded-[18px] py-2.5 px-4 text-sm font-medium text-[#4A5D23]\" data-kid=\"147\">\n              </div>\n            </div>\n\n            <div class=\"flex items-center gap-1.5 ml-1\" data-kid=\"148\">\n              <span class=\"text-[11px] text-emerald-600 font-bold bg-emerald-50 px-2 py-0.5 rounded-md\" data-kid=\"149\"><i class=\"ti ti-circle-check-filled mr-1\" data-kid=\"150\"></i>Passwords match</span>\n              <span class=\"text-[11px] text-[#E3256B] font-bold bg-[#E3256B]/5 px-2 py-0.5 rounded-md\" data-kid=\"151\">Strong</span>\n            </div>\n\n            <button onclick=\"simulateAuthSuccess('signup')\" class=\"w-full bg-[#E3256B] hover:bg-[#E3256B]/90 text-white font-heading font-bold py-3.5 rounded-[18px] transition-all razz-shadow cursor-pointer text-sm\" data-kid=\"152\">\n              Register Bloom Profile\n            </button>\n\n            <p class=\"text-center text-xs text-[#4A5D23]/60 font-semibold mt-1\" data-kid=\"153\">\n              Already have an account? \n              <button onclick=\"switchView('login')\" class=\"text-[#E3256B] font-bold hover:underline cursor-pointer\" data-kid=\"154\">Warm Sign In</button>\n            </p>\n          </div>\n        </div>\n      </div>\n\n    </div>\n\n    \n    <div id=\"feedback-alert\" class=\"hidden absolute top-24 left-1/2 -translate-x-1/2 z-50 bg-[#4A5D23] text-white py-3 px-6 rounded-full shadow-2xl flex items-center gap-3 animate-slide-up border border-[#E3256B]/20\" data-kid=\"155\">\n      <div class=\"w-6 h-6 rounded-full bg-[#E3256B] flex items-center justify-center\" data-kid=\"156\">\n        <i class=\"ti ti-bell-ringing text-xs\" data-kid=\"157\"></i>\n      </div>\n      <span id=\"alert-text\" class=\"text-xs font-heading font-bold\" data-kid=\"158\">Empathic alert activated.</span>\n    </div>\n\n  </div>\n\n  \n  <script data-kid=\"159\">\n    // Tab switching routing\n    function switchView(viewId) {\n      const views = ['chat', 'login', 'signup'];\n      views.forEach(v => {\n        const viewEl = document.getElementById('view-' + v);\n        const tabEl = document.getElementById('tab-' + v);\n        \n        if (v === viewId) {\n          viewEl.classList.remove('hidden');\n          tabEl.className = \"px-5 py-2 rounded-full text-sm font-heading font-semibold transition-all duration-300 clay-pill-active cursor-pointer\";\n        } else {\n          viewEl.classList.add('hidden');\n          tabEl.className = \"px-5 py-2 rounded-full text-sm font-heading font-semibold text-[#4A5D23]/70 hover:text-[#4A5D23] transition-all duration-300 cursor-pointer\";\n        }\n      });\n    }\n\n    // Dynamic Topic Selection & Conversational responses\n    function selectTopic(topic) {\n      let userText = \"\";\n      let botResponse = \"\";\n      let illustrationHtml = \"\";\n\n      if (topic === 'lungs') {\n        userText = \"Can we look at my respiratory alveolar pattern and lung detail?\";\n        illustrationHtml = `\n          <div class=\"my-3 rounded-[24px] overflow-hidden border-2 border-white shadow-md max-w-sm\">\n            <img src=\"https://images.unsplash.com/photo-1715529407875-7f1c7176d074?auto=format&w=600&q=80&fit=crop\" alt=\"Detailed Lung Drawing\" class=\"w-full h-auto object-cover\" decoding=\"async\" loading=\"lazy\">\n            <div class=\"p-3 bg-white/90 text-[11px] text-[#4A5D23]/70 font-semibold italic\">\n              Fig A: Intricate bronchial structure & alveolar pathway rendering.\n            </div>\n          </div>\n        `;\n        botResponse = `\n          I've fetched your personalized clinical illustration of the pulmonary system. Look closely at the bronchial branching. Your breathing rhythm indicates a soft shallow intake. I highly recommend spending 5 minutes in a warm, moist room or doing a gentle chamomile steam treatment. Shall we do a guided breath exercises now?\n        `;\n      } else if (topic === 'symptom') {\n        userText = \"I have a slight persistent dry cough. Is it alarming?\";\n        botResponse = `\n          I hear you, and please rest assured that dry coughs can often be a friendly biological response to clean dust or adjust to temperature transitions. Since your sleep score is high (98%), it is likely benign. Let's record if it occurs more during mornings or evenings.\n        `;\n      } else if (topic === 'medication') {\n        userText = \"How is my prescription medication plan doing today?\";\n        botResponse = `\n          Your medication dashboard is looking great! You have successfully logged your morning supplements. Your remaining tablet of organic multivitamin is scheduled for 8:00 PM tonight. I will gently chime to remind you then. Keep staying hydrated!\n        `;\n      }\n\n      appendMessage(userText, 'user');\n      \n      // Simulated compassionate delay\n      setTimeout(() => {\n        appendMessage(botResponse, 'bot', illustrationHtml);\n      }, 700);\n    }\n\n    // Append Message to UI\n    function appendMessage(text, sender, extraHtml = \"\") {\n      const hook = document.getElementById('dynamic-messages-hook');\n      const scroller = document.getElementById('chat-scroller');\n      \n      let msgHtml = \"\";\n      if (sender === 'user') {\n        msgHtml = `\n          <div class=\"flex items-start justify-end gap-3 animate-slide-up\">\n            <div class=\"max-w-[80%] rounded-[24px_2px_24px_24px] bg-[#E3256B] p-4.5 text-white shadow-sm font-semibold text-sm razz-shadow\">\n              <p>${text}</p>\n            </div>\n            <div class=\"w-9 h-9 rounded-full border border-[#E3256B]/30 overflow-hidden shrink-0\">\n              <img src=\"https://i.pravatar.cc/100?u=kesav\" alt=\"User\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\">\n            </div>\n          </div>\n        `;\n      } else {\n        msgHtml = `\n          <div class=\"flex items-start gap-3 animate-slide-up\">\n            <div class=\"w-10 h-10 rounded-[60%_40%_30%_70%/60%_30%_70%_40%] bg-[#FFEBE7] flex items-center justify-center text-[#E3256B] shrink-0 mt-1 border border-[#E3256B]/20\">\n              <i class=\"ti ti-seedling text-lg\"></i>\n            </div>\n            <div class=\"max-w-[80%] rounded-[2px_24px_24px_24px] bg-white p-5 shadow-sm border border-white/80\">\n              <p class=\"text-sm leading-relaxed text-[#4A5D23] font-medium\">${text}</p>\n              ${extraHtml}\n            </div>\n          </div>\n        `;\n      }\n\n      hook.insertAdjacentHTML('beforeend', msgHtml);\n      \n      // Auto-scroll inside locked viewport container\n      setTimeout(() => {\n        scroller.scrollTop = scroller.scrollHeight;\n      }, 100);\n    }\n\n    // Handle Custom Written text\n    function handleSend(event) {\n      event.preventDefault();\n      const input = document.getElementById('chat-input');\n      const text = input.value.trim();\n      if (!text) return;\n\n      appendMessage(text, 'user');\n      input.value = \"\";\n\n      // Compassionate generic response\n      setTimeout(() => {\n        appendMessage(\"I hear you completely and am absorbing your query. Let's explore your vital patterns to address this with maximum warmth. Tell me, do you feel any companion tightness in your breathing?\", 'bot');\n      }, 700);\n    }\n\n    // Interactive Account Success Toast feedback\n    function simulateAuthSuccess(type) {\n      const alert = document.getElementById('feedback-alert');\n      const alertText = document.getElementById('alert-text');\n      \n      if (type === 'login') {\n        alertText.innerText = \"Welcome back, Kesavardhan! Secure session initiated.\";\n      } else {\n        alertText.innerText = \"Organic Profile registered! Verification email sent.\";\n      }\n\n      alert.classList.remove('hidden');\n      setTimeout(() => {\n        alert.classList.add('hidden');\n        switchView('chat');\n      }, 3000);\n    }\n  </script>\n</div>\n",
