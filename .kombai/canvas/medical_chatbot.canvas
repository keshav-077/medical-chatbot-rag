      },
      "html": "\n<div class=\"w-full bg-[#010B13] text-slate-100 font-['Fira_Sans',sans-serif] min-h-[800px] h-[800px] flex flex-col justify-between relative overflow-hidden selection:bg-[#00FFFF]/30 selection:text-[#00FFFF]\" data-kid=\"0\">\n  \n  <style data-kid=\"1\">\n    @import url('https://fonts.googleapis.com/css2?family=Fira+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Space+Grotesk:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap');\n    @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css');\n\n    .font-hud {\n      font-family: 'Space Grotesk', sans-serif;\n    }\n    .font-mono-tech {\n      font-family: 'Fira Code', monospace;\n    }\n\n    /* Cyber grid overlay */\n    .grid-overlay {\n      background-size: 40px 40px;\n      background-image: \n        linear-gradient(to right, rgba(17, 100, 180, 0.08) 1px, transparent 1px),\n        linear-gradient(to bottom, rgba(17, 100, 180, 0.08) 1px, transparent 1px);\n    }\n\n    /* Custom scrollbars */\n    .custom-scroll::-webkit-scrollbar {\n      width: 6px;\n      height: 6px;\n    }\n    .custom-scroll::-webkit-scrollbar-track {\n      background: rgba(1, 11, 19, 0.5);\n    }\n    .custom-scroll::-webkit-scrollbar-thumb {\n      background: rgba(0, 255, 255, 0.2);\n      border-radius: 3px;\n    }\n    .custom-scroll::-webkit-scrollbar-thumb:hover {\n      background: rgba(0, 255, 255, 0.4);\n    }\n\n    /* HUD Frame border polygon */\n    .hud-border {\n      border: 1px solid rgba(0, 255, 255, 0.2);\n      box-shadow: 0 0 15px rgba(0, 255, 255, 0.05);\n      position: relative;\n    }\n    .hud-border::before {\n      content: '';\n      position: absolute;\n      top: -1px; left: -1px;\n      width: 12px; height: 12px;\n      border-top: 2px solid #00FFFF;\n      border-left: 2px solid #00FFFF;\n    }\n    .hud-border::after {\n      content: '';\n      position: absolute;\n      bottom: -1px; right: -1px;\n      width: 12px; height: 12px;\n      border-bottom: 2px solid #00FFFF;\n      border-right: 2px solid #00FFFF;\n    }\n\n    /* Corner cuts */\n    .cut-corner-bubble {\n      clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 0 100%);\n    }\n\n    /* Animation effects */\n    @keyframes scanline {\n      0% { transform: translateY(-100%); }\n      100% { transform: translateY(100%); }\n    }\n    .scanning-laser {\n      animation: scanline 4s linear infinite;\n    }\n\n    @keyframes pulse-cyan {\n      0%, 100% { opacity: 0.2; }\n      50% { opacity: 0.6; }\n    }\n    .neon-pulse {\n      animation: pulse-cyan 2s infinite ease-in-out;\n    }\n  </style>\n\n  \n  <div class=\"absolute inset-0 grid-overlay pointer-events-none z-0\" data-kid=\"2\"></div>\n  <div class=\"absolute inset-x-0 h-0.5 bg-cyan-500/20 shadow-[0_0_15px_#00FFFF] scanning-laser pointer-events-none z-10\" data-kid=\"3\"></div>\n\n  \n  <div class=\"flex flex-col h-full z-10\" id=\"main-container\" data-active-tab=\"terminal\" data-active-visual=\"brain\" data-has-queried=\"false\" data-kid=\"4\">\n\n    \n    <header class=\"border-b border-cyan-500/20 bg-[#010B13]/90 backdrop-blur-md px-6 py-3 flex items-center justify-between shrink-0\" data-kid=\"5\">\n      <div class=\"flex items-center gap-4\" data-kid=\"6\">\n        \n        <div class=\"relative flex h-3 w-3\" data-kid=\"7\">\n          <span class=\"animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75\" data-kid=\"8\"></span>\n          <span class=\"relative inline-flex rounded-full h-3 w-3 bg-cyan-500\" data-kid=\"9\"></span>\n        </div>\n        <div class=\"flex items-center gap-2\" data-kid=\"10\">\n          <i class=\"ti ti-activity-heartbeat text-cyan-400 text-xl\" data-kid=\"11\"></i>\n          <span class=\"font-hud font-bold tracking-wider text-[#00FFFF] text-sm\" data-kid=\"12\">AEGIS_MED_HUD v4.8</span>\n        </div>\n        <div class=\"hidden md:flex items-center gap-1.5 px-2 py-0.5 rounded bg-cyan-950/40 border border-cyan-500/30 text-[10px] font-mono-tech text-cyan-300\" data-kid=\"13\">\n          <span class=\"w-1.5 h-1.5 rounded-full bg-[#FF004F] animate-pulse\" data-kid=\"14\"></span>\n          SECURE QUANTUM LINK\n        </div>\n      </div>\n\n      \n      <nav class=\"flex bg-cyan-950/25 p-0.5 rounded border border-cyan-500/30\" aria-label=\"HUD State Selector\" data-kid=\"15\">\n        <button onclick=\"switchState('terminal')\" id=\"tab-btn-terminal\" class=\"px-5 py-2 text-xs font-hud tracking-widest transition-all duration-300 flex items-center gap-2 bg-[#00FFFF]/15 border-b-2 border-[#00FFFF] text-[#00FFFF] font-bold cursor-pointer\" data-kid=\"16\">\n          <span class=\"text-xs font-mono-tech\" data-kid=\"17\">&lt;</span>HUD_TERMINAL<span class=\"text-xs font-mono-tech\" data-kid=\"18\">&gt;</span>\n        </button>\n        <button onclick=\"switchState('signin')\" id=\"tab-btn-signin\" class=\"px-5 py-2 text-xs font-hud tracking-widest text-slate-300 hover:text-[#00FFFF] hover:bg-cyan-950/35 transition-all duration-300 flex items-center gap-2 border-b-2 border-transparent cursor-pointer\" data-kid=\"19\">\n          SIGN_IN_DIAG\n        </button>\n        <button onclick=\"switchState('signup')\" id=\"tab-btn-signup\" class=\"px-5 py-2 text-xs font-hud tracking-widest text-slate-300 hover:text-[#00FFFF] hover:bg-cyan-950/35 transition-all duration-300 flex items-center gap-2 border-b-2 border-transparent cursor-pointer\" data-kid=\"20\">\n          BIOMETRIC_SIGNUP\n        </button>\n      </nav>\n\n      \n      <div class=\"hidden lg:flex items-center gap-6 font-mono-tech text-[11px] text-cyan-400/70\" data-kid=\"21\">\n        <div data-kid=\"22\">SYS_LOAD: <span class=\"text-cyan-300\" data-kid=\"23\">14.2%</span></div>\n        <div data-kid=\"24\">LATENCY: <span class=\"text-cyan-300\" data-kid=\"25\">8ms</span></div>\n        <div data-kid=\"26\">DIAG_DB: <span class=\"text-emerald-400\" data-kid=\"27\">ONLINE</span></div>\n      </div>\n    </header>\n\n    \n    <main id=\"screen-terminal\" class=\"flex-1 flex overflow-hidden\" data-kid=\"28\">\n      \n      \n      <div class=\"w-7/12 border-r border-cyan-500/20 flex flex-col justify-between bg-[#010b13]/40 relative\" data-kid=\"29\">\n        \n        <div class=\"absolute left-0 top-0 bottom-0 w-[2px] bg-gradient-to-b from-[#00FFFF]/0 via-[#00FFFF]/30 to-[#00FFFF]/0\" data-kid=\"30\"></div>\n\n        \n        <div class=\"flex-1 overflow-y-auto p-6 space-y-6 custom-scroll\" id=\"chat-messages-container\" data-kid=\"31\">\n          \n          \n          <div id=\"terminal-diagnostics-welcome\" class=\"space-y-4 pt-2\" data-kid=\"32\">\n            <div class=\"p-5 bg-cyan-950/10 border border-cyan-500/20 rounded relative overflow-hidden\" data-kid=\"33\">\n              <div class=\"absolute -right-16 -top-16 w-36 h-36 bg-cyan-500/5 rounded-full blur-2xl\" data-kid=\"34\"></div>\n              <div class=\"flex items-start gap-4\" data-kid=\"35\">\n                <div class=\"p-3 bg-cyan-950/40 border border-cyan-400/30 rounded text-cyan-400\" data-kid=\"36\">\n                  <i class=\"ti ti-binary text-xl\" data-kid=\"37\"></i>\n                </div>\n                <div class=\"flex-1\" data-kid=\"38\">\n                  <h3 class=\"font-hud text-base font-bold text-white tracking-wide flex items-center gap-2\" data-kid=\"39\">\n                    AEGIS HEALTH QUANTUM CORE\n                    <span class=\"text-[10px] font-mono-tech px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-400 border border-emerald-500/20\" data-kid=\"40\">READY</span>\n                  </h3>\n                  <p class=\"text-slate-400 text-xs mt-0.5\" data-kid=\"41\">Advanced neurological, cardiovascular, and skeletal AI analytical subsystem.</p>\n                </div>\n              </div>\n\n              \n              <div class=\"mt-4 p-3 bg-slate-950/60 rounded border border-cyan-500/10 font-mono-tech text-[11px] text-cyan-400/90 space-y-1\" data-kid=\"42\">\n                <div class=\"flex items-center gap-2\" data-kid=\"43\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-[#00FFFF] animate-ping\" data-kid=\"44\"></span>\n                  <span data-kid=\"45\">[OK] Core memory stack mounted.</span>\n                </div>\n                <div data-kid=\"46\">[OK] Human Anatomical Mapping Layer initialized.</div>\n                <div class=\"text-[#00FFFF] font-bold\" data-kid=\"47\">Medical Database Online... Awaiting Query <span class=\"animate-pulse\" data-kid=\"48\">_</span></div>\n              </div>\n            </div>\n\n            \n            <div data-kid=\"49\">\n              <p class=\"text-[11px] font-hud uppercase tracking-widest text-cyan-400/60 mb-2 flex items-center gap-1.5\" data-kid=\"50\">\n                <span class=\"w-1.5 h-1.5 bg-[#FF004F] animate-pulse rounded-full\" data-kid=\"51\"></span>\n                SELECT DIAGNOSTIC TARGET FIELD\n              </p>\n              <div class=\"flex flex-col gap-2 font-mono-tech text-xs\" data-kid=\"52\">\n                <button onclick=\"triggerQuickQuery('brain')\" class=\"w-full p-2.5 bg-cyan-950/10 hover:bg-cyan-950/30 border border-cyan-500/20 hover:border-[#00FFFF] transition-all text-left rounded flex items-center justify-between group cursor-pointer\" data-kid=\"53\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"54\">\n                    <span class=\"text-cyan-400/50 group-hover:text-[#00FFFF] font-bold\" data-kid=\"55\">&gt;&gt; CMD_01:</span>\n                    <span class=\"text-white font-bold\" data-kid=\"56\">NEURO_CRANIAL_DEEP_DIVE_SCAN</span>\n                  </div>\n                  <div class=\"flex items-center gap-2 text-cyan-400\" data-kid=\"57\">\n                    <span class=\"text-[10px] opacity-60 group-hover:opacity-100\" data-kid=\"58\">TARGET: BRAIN</span>\n                    <i class=\"ti ti-brain text-base text-[#00FFFF]\" data-kid=\"59\"></i>\n                  </div>\n                </button>\n\n                <button onclick=\"triggerQuickQuery('cardio')\" class=\"w-full p-2.5 bg-cyan-950/10 hover:bg-cyan-950/30 border border-cyan-500/20 hover:border-[#FF004F] transition-all text-left rounded flex items-center justify-between group cursor-pointer\" data-kid=\"60\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"61\">\n                    <span class=\"text-[#FF004F]/60 group-hover:text-[#FF004F] font-bold\" data-kid=\"62\">&gt;&gt; CMD_02:</span>\n                    <span class=\"text-white font-bold\" data-kid=\"63\">CARDIO_EKG_TELEMETRY_SYNC</span>\n                  </div>\n                  <div class=\"flex items-center gap-2 text-[#FF004F]\" data-kid=\"64\">\n                    <span class=\"text-[10px] opacity-60 group-hover:opacity-100\" data-kid=\"65\">TARGET: CARDIO</span>\n                    <i class=\"ti ti-activity-heartbeat text-base animate-pulse\" data-kid=\"66\"></i>\n                  </div>\n                </button>\n\n                <button onclick=\"triggerQuickQuery('skeletal')\" class=\"w-full p-2.5 bg-cyan-950/10 hover:bg-cyan-950/30 border border-cyan-500/20 hover:border-[#00FFFF] transition-all text-left rounded flex items-center justify-between group cursor-pointer\" data-kid=\"67\">\n                  <div class=\"flex items-center gap-3\" data-kid=\"68\">\n                    <span class=\"text-cyan-400/50 group-hover:text-[#00FFFF] font-bold\" data-kid=\"69\">&gt;&gt; CMD_03:</span>\n                    <span class=\"text-white font-bold\" data-kid=\"70\">SKELETAL_XRAY_DENSITY_RECON</span>\n                  </div>\n                  <div class=\"flex items-center gap-2 text-cyan-400\" data-kid=\"71\">\n                    <span class=\"text-[10px] opacity-60 group-hover:opacity-100\" data-kid=\"72\">TARGET: SKELETON</span>\n                    <i class=\"ti ti-bone text-base text-cyan-300\" data-kid=\"73\"></i>\n                  </div>\n                </button>\n              </div>\n            </div>\n          </div>\n\n          \n          <div id=\"active-conversation-stream\" class=\"hidden space-y-6\" data-kid=\"74\">\n            \n            <div class=\"flex justify-end gap-3\" data-kid=\"75\">\n              <div class=\"max-w-[80%] bg-cyan-950/30 border border-cyan-500/30 text-cyan-200 px-4 py-3 text-sm rounded-lg\" data-kid=\"76\">\n                <p class=\"font-hud font-bold text-xs text-[#00FFFF] mb-1\" data-kid=\"77\">USER SECURE REQUEST</p>\n                <p id=\"chat-user-question\" class=\"font-mono-tech text-xs\" data-kid=\"78\">Awaiting input...</p>\n              </div>\n              <div class=\"w-8 h-8 rounded bg-cyan-950 border border-cyan-500/40 flex items-center justify-center text-[#00FFFF] text-sm shrink-0 font-bold font-hud\" data-kid=\"79\">\n                U1\n              </div>\n            </div>\n\n            \n            <div class=\"flex gap-3\" data-kid=\"80\">\n              <div class=\"w-8 h-8 rounded bg-[#1164B4]/20 border border-[#00FFFF]/40 flex items-center justify-center text-[#00FFFF] text-lg shrink-0\" data-kid=\"81\">\n                <i class=\"ti ti-robot\" data-kid=\"82\"></i>\n              </div>\n              <div class=\"max-w-[80%] bg-gradient-to-br from-[#1164B4]/20 to-slate-950 border-l-2 border-[#00FFFF] text-slate-200 p-4 cut-corner-bubble relative\" data-kid=\"83\">\n                \n                <div class=\"flex items-center justify-between border-b border-cyan-500/10 pb-2 mb-2\" data-kid=\"84\">\n                  <span class=\"font-hud font-bold text-xs text-[#00FFFF] tracking-widest uppercase flex items-center gap-1\" data-kid=\"85\">\n                    <span class=\"w-1.5 h-1.5 rounded-full bg-cyan-400 animate-ping\" data-kid=\"86\"></span>\n                    AI DIAGNOSTIC SUBSYSTEM\n                  </span>\n                  <span class=\"text-[10px] font-mono-tech text-slate-400\" data-kid=\"87\">99.8% CONFIDENCE</span>\n                </div>\n                \n                <p id=\"chat-ai-answer\" class=\"text-xs leading-relaxed font-mono-tech\" data-kid=\"88\">Analyzing telemetry data...</p>\n\n                \n                <div class=\"mt-3 p-2 bg-[#FF004F]/10 border border-[#FF004F]/30 text-xs text-[#FF004F] flex items-center gap-2\" data-kid=\"89\">\n                  <i class=\"ti ti-alert-triangle animate-pulse\" data-kid=\"90\"></i>\n                  <span data-kid=\"91\">Warning: Diagnostic output for simulated analysis. Contact a primary care physician.</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n        </div>\n\n        \n        <div class=\"p-4 border-t border-cyan-500/20 bg-[#010b13]/80\" data-kid=\"92\">\n          <form onsubmit=\"handleChatSubmit(event)\" class=\"relative flex items-center\" data-kid=\"93\">\n            <span class=\"absolute left-4 text-[#00FFFF] font-mono-tech text-xs select-none font-bold\" data-kid=\"94\">AEGIS_SYS&gt;</span>\n            <input type=\"text\" id=\"chat-input\" placeholder=\"Type medical query or scan requirement (e.g., 'heart pulse' or 'X-ray')...\" class=\"w-full pl-32 pr-12 py-3 bg-slate-950 border border-cyan-500/50 focus:border-[#00FFFF] focus:outline-none focus:ring-1 focus:ring-[#00FFFF] text-xs font-mono-tech text-[#00FFFF] tracking-wider rounded transition-all placeholder-cyan-400/40\" data-kid=\"95\">\n            <button type=\"submit\" class=\"absolute right-2 p-2 bg-[#00FFFF] text-slate-950 hover:bg-cyan-300 transition-all rounded text-sm font-bold flex items-center justify-center cursor-pointer shadow-[0_0_8px_rgba(0,255,255,0.6)]\" data-kid=\"96\">\n              <i class=\"ti ti-send\" data-kid=\"97\"></i>\n            </button>\n          </form>\n          <div class=\"mt-2 flex items-center justify-between px-1 text-[10px] text-slate-500 font-mono-tech\" data-kid=\"98\">\n            <div data-kid=\"99\">PRESS [ENTER] TO TRANSMIT SCAN DEMAND</div>\n            <div class=\"flex items-center gap-2\" data-kid=\"100\">\n              <span class=\"flex items-center gap-1\" data-kid=\"101\"><span class=\"w-1.5 h-1.5 rounded-full bg-emerald-500\" data-kid=\"102\"></span> SECURE SHELL</span>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"w-5/12 bg-slate-950/40 p-6 flex flex-col justify-between relative overflow-hidden\" data-kid=\"103\">\n        \n        \n        <div class=\"space-y-4 flex-1 flex flex-col justify-between\" data-kid=\"104\">\n          \n          \n          <div class=\"border-b border-cyan-500/10 pb-3\" data-kid=\"105\">\n            <div class=\"flex items-center justify-between\" data-kid=\"106\">\n              <div class=\"flex items-center gap-2\" data-kid=\"107\">\n                <i class=\"ti ti-drone text-[#00FFFF] text-lg animate-pulse\" data-kid=\"108\"></i>\n                <h3 class=\"font-hud font-bold tracking-wider text-sm text-white uppercase\" data-kid=\"109\">ANATOMICAL SCANNER MATRIX</h3>\n              </div>\n              <span class=\"text-[10px] font-mono-tech px-2 py-0.5 rounded bg-cyan-950/40 border border-cyan-500/20 text-[#00FFFF]\" data-kid=\"110\">ACTIVE GRAPHICS</span>\n            </div>\n          </div>\n\n          \n          <div class=\"relative flex-1 flex items-center justify-center my-4 rounded border border-cyan-500/20 bg-[#010B13]/80 overflow-hidden hud-border\" data-kid=\"111\">\n            \n            \n            \n            <div id=\"visual-brain\" class=\"absolute inset-0 flex flex-col items-center justify-center transition-opacity duration-500 opacity-100\" data-kid=\"112\">\n              <video src=\"https://videos.pexels.com/video-files/13808077/13808077-hd_1280_720_25fps.mp4\" poster=\"https://images.pexels.com/videos/13808077/ekg-hologram-medical-pulse-13808077.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover opacity-90\" data-kid=\"113\"></video>\n              <div class=\"absolute inset-0 bg-[#00FFFF]/5 mix-blend-color pointer-events-none\" data-kid=\"114\"></div>\n              <div class=\"absolute inset-x-0 bottom-4 text-center z-20\" data-kid=\"115\">\n                <div class=\"inline-block bg-slate-950/90 border border-[#00FFFF]/50 px-3 py-1 rounded text-[10px] font-mono-tech text-[#00FFFF] shadow-[0_0_8px_rgba(0,255,255,0.3)]\" data-kid=\"116\">\n                  CRANIAL TELEMETRY FEED: 25 FPS // NEURO_STK\n                </div>\n              </div>\n            </div>\n\n            \n            <div id=\"visual-cardio\" class=\"absolute inset-0 flex flex-col items-center justify-center transition-opacity duration-500 opacity-0 pointer-events-none\" data-kid=\"117\">\n              \n              <video src=\"https://videos.pexels.com/video-files/18388881/18388881-sd_720_540_30fps.mp4\" poster=\"https://images.pexels.com/videos/18388881/animation-18388881.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline preload=\"metadata\" class=\"w-full h-full object-cover opacity-90\" data-kid=\"118\"></video>\n              <div class=\"absolute inset-0 bg-[#FF004F]/10 mix-blend-color pointer-events-none\" data-kid=\"119\"></div>\n              <div class=\"absolute inset-x-0 bottom-4 text-center z-20\" data-kid=\"120\">\n                <div class=\"inline-block bg-slate-950/90 border border-[#FF004F]/60 px-3 py-1 rounded text-[10px] font-mono-tech text-[#FF004F] shadow-[0_0_8px_rgba(255,0,79,0.3)]\" data-kid=\"121\">\n                  CARDIO_PULSE_HOLOGRAM: ACTIVE_WARN\n                </div>\n              </div>\n            </div>\n\n            \n            <div id=\"visual-skeletal\" class=\"absolute inset-0 flex flex-col items-center justify-center transition-opacity duration-500 opacity-0 pointer-events-none\" data-kid=\"122\">\n              <img src=\"https://images.unsplash.com/photo-1763198302535-265c44183bcb?auto=format&w=600&q=80&fit=crop\" alt=\"Xray skeleton\" class=\"w-full h-full object-cover opacity-70 mix-blend-screen\" decoding=\"async\" loading=\"lazy\" data-kid=\"123\">\n              <div class=\"absolute inset-x-0 bottom-4 text-center\" data-kid=\"124\">\n                <div class=\"inline-block bg-slate-950/80 border border-[#00FFFF]/30 px-3 py-1 rounded text-[10px] font-mono-tech text-[#00FFFF]\" data-kid=\"125\">\n                  SKELETAL MAP LAYER: XRAY_DENSITY\n                </div>\n              </div>\n            </div>\n\n            \n            <div class=\"absolute inset-0 border border-cyan-500/10 pointer-events-none flex items-center justify-center\" data-kid=\"126\">\n              <div class=\"w-12 h-12 border border-[#FF004F]/30 rounded-full animate-ping\" data-kid=\"127\"></div>\n              \n              <div class=\"absolute w-6 h-px bg-[#FF004F]/40\" data-kid=\"128\"></div>\n              <div class=\"absolute h-6 w-px bg-[#FF004F]/40\" data-kid=\"129\"></div>\n              <div class=\"absolute top-2 left-2 text-cyan-500/40 text-[9px] font-mono-tech\" data-kid=\"130\">[SYS_RNDR: OK]</div>\n              <div class=\"absolute top-2 right-2 text-cyan-500/40 text-[9px] font-mono-tech\" data-kid=\"131\">MAG: 4.8X</div>\n              <div class=\"absolute bottom-2 left-2 text-[#FF004F]/60 text-[9px] font-mono-tech\" data-kid=\"132\">PULSE: DETECT_LINK</div>\n            </div>\n\n          </div>\n\n          \n          <div class=\"bg-slate-950/60 p-4 border border-cyan-500/20 rounded-lg\" data-kid=\"133\">\n            <h4 class=\"font-hud font-bold text-xs text-[#00FFFF] uppercase tracking-wider mb-2\" data-kid=\"134\">VITAL SIGN DIAGNOSTICS</h4>\n            <div class=\"grid grid-cols-2 gap-4 text-xs font-mono-tech\" data-kid=\"135\">\n              <div class=\"p-2.5 bg-cyan-950/20 border border-cyan-500/10 rounded\" data-kid=\"136\">\n                <div class=\"text-slate-400 text-[10px]\" data-kid=\"137\">CEREBRAL BLOOD FLOW</div>\n                <div class=\"text-white font-bold text-sm mt-0.5\" id=\"metric-cbv\" data-kid=\"138\">75 ml/100g</div>\n                <div class=\"text-[9px] text-[#00FFFF]\" data-kid=\"139\">SYS_OK</div>\n              </div>\n              <div class=\"p-2.5 bg-cyan-950/20 border border-cyan-500/10 rounded\" data-kid=\"140\">\n                <div class=\"text-slate-400 text-[10px]\" data-kid=\"141\">PULSE METRICS</div>\n                <div class=\"text-[#FF004F] font-bold text-sm mt-0.5\" id=\"metric-pulse\" data-kid=\"142\">72 BPM</div>\n                <div class=\"text-[9px] text-emerald-400\" data-kid=\"143\">NOMINAL STATE</div>\n              </div>\n            </div>\n          </div>\n\n        </div>\n\n      </div>\n    </main>\n\n    \n    <main id=\"screen-signin\" class=\"hidden flex-1 flex overflow-hidden\" data-kid=\"144\">\n      \n      <div class=\"w-full h-full flex\" data-kid=\"145\">\n        \n        \n        <div class=\"w-1/2 p-12 flex flex-col justify-center bg-[#010B13]/90 relative border-r border-cyan-500/20\" data-kid=\"146\">\n          <div class=\"max-w-md mx-auto w-full space-y-6\" data-kid=\"147\">\n            <div class=\"space-y-2\" data-kid=\"148\">\n              <div class=\"inline-flex items-center gap-1.5 px-2 py-0.5 rounded bg-cyan-950/50 border border-cyan-500/30 text-[10px] font-mono-tech text-cyan-300\" data-kid=\"149\">\n                <span class=\"w-1.5 h-1.5 rounded-full bg-cyan-400\" data-kid=\"150\"></span>\n                SIGNIN TO MEDICAL HUB\n              </div>\n              <h2 class=\"text-3xl font-hud font-bold text-white tracking-tight\" data-kid=\"151\">Welcome Back Operator</h2>\n              <p class=\"text-slate-400 text-sm\" data-kid=\"152\">Synchronize biometric token and access state diagnostics.</p>\n            </div>\n\n            \n            <div class=\"p-3 bg-cyan-950/40 border border-cyan-400/30 rounded text-xs text-cyan-200 flex items-center gap-2\" data-kid=\"153\">\n              <i class=\"ti ti-shield-check text-cyan-400 text-base\" data-kid=\"154\"></i>\n              <span data-kid=\"155\">Account created successfully! Please authenticate terminal.</span>\n            </div>\n\n            \n            <form onsubmit=\"switchState('terminal'); return false;\" class=\"space-y-4\" data-kid=\"156\">\n              <div class=\"space-y-1\" data-kid=\"157\">\n                <label class=\"text-xs font-hud font-bold text-cyan-400 tracking-wider block uppercase\" data-kid=\"158\">EMAIL ADDRESS</label>\n                <div class=\"relative\" data-kid=\"159\">\n                  <span class=\"absolute left-3.5 top-1/2 -translate-y-1/2 text-cyan-500/50\" data-kid=\"160\"><i class=\"ti ti-mail\" data-kid=\"161\"></i></span>\n                  <input type=\"email\" value=\"kesavardhan775@gmail.com\" required class=\"w-full pl-10 pr-4 py-3 bg-slate-950/80 border border-cyan-500/30 text-cyan-200 focus:border-[#00FFFF] focus:outline-none focus:ring-1 focus:ring-[#00FFFF] text-xs font-mono-tech rounded\" data-kid=\"162\">\n                </div>\n              </div>\n\n              <div class=\"space-y-1\" data-kid=\"163\">\n                <div class=\"flex justify-between items-center\" data-kid=\"164\">\n                  <label class=\"text-xs font-hud font-bold text-cyan-400 tracking-wider block uppercase\" data-kid=\"165\">ACCESS TOKEN / PASSWORD</label>\n                  <a href=\"#\" class=\"text-[10px] text-cyan-500 hover:text-cyan-400 font-mono-tech\" data-kid=\"166\">RESET TERMINAL</a>\n                </div>\n                <div class=\"relative\" data-kid=\"167\">\n                  <span class=\"absolute left-3.5 top-1/2 -translate-y-1/2 text-cyan-500/50\" data-kid=\"168\"><i class=\"ti ti-lock\" data-kid=\"169\"></i></span>\n                  <input type=\"password\" value=\"Realmegt3t@\" required class=\"w-full pl-10 pr-4 py-3 bg-slate-950/80 border border-cyan-500/30 text-cyan-200 focus:border-[#00FFFF] focus:outline-none focus:ring-1 focus:ring-[#00FFFF] text-xs font-mono-tech rounded\" data-kid=\"170\">\n                </div>\n              </div>\n\n              <div class=\"flex items-center justify-between py-2 text-xs font-mono-tech\" data-kid=\"171\">\n                <label class=\"flex items-center gap-2 text-slate-400 cursor-pointer\" data-kid=\"172\">\n                  <input type=\"checkbox\" checked class=\"accent-cyan-500 bg-slate-900 border-cyan-500\" data-kid=\"173\">\n                  <span data-kid=\"174\">REMEMBER DEVICE SECURELY</span>\n                </label>\n              </div>\n\n              <button type=\"submit\" class=\"w-full py-3 bg-gradient-to-r from-cyan-500 to-[#1164B4] text-slate-950 hover:to-cyan-400 transition-all font-hud font-bold tracking-widest text-xs uppercase rounded shadow-[0_0_15px_rgba(0,255,255,0.3)]\" data-kid=\"175\">\n                AUTHENTICATE TERMINAL &rarr;\n              </button>\n            </form>\n\n            <p class=\"text-center text-xs font-mono-tech text-slate-500\" data-kid=\"176\">\n              New system diagnostic request? <button onclick=\"switchState('signup')\" class=\"text-cyan-400 hover:underline\" data-kid=\"177\">Provision account</button>\n            </p>\n          </div>\n        </div>\n\n        \n        <div class=\"w-1/2 relative overflow-hidden bg-slate-950\" data-kid=\"178\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[#010B13] via-transparent to-[#010B13] z-10\" data-kid=\"179\"></div>\n          \n          <img src=\"https://images.unsplash.com/photo-1763198302243-51142ba5b24a?auto=format&w=600&q=80&fit=crop\" alt=\"Cyan skeleton illustration\" class=\"w-full h-full object-cover opacity-60 mix-blend-screen\" decoding=\"async\" loading=\"lazy\" data-kid=\"180\">\n          <div class=\"absolute bottom-8 right-8 z-20 bg-slate-950/90 border border-cyan-500/30 p-4 rounded max-w-xs font-mono-tech text-[11px] text-cyan-400/90\" data-kid=\"181\">\n            <div class=\"font-bold text-white mb-1\" data-kid=\"182\">&lt;BIOMETRIC_ANATOMY_GRID&gt;</div>\n            Scanning device credentials using anatomical validation protocols.\n          </div>\n        </div>\n\n      </div>\n    </main>\n\n    \n    <main id=\"screen-signup\" class=\"hidden flex-1 flex overflow-hidden\" data-kid=\"183\">\n      \n      <div class=\"w-full h-full flex\" data-kid=\"184\">\n        \n        \n        <div class=\"w-1/2 p-12 flex flex-col justify-center bg-[#010B13]/90 relative border-r border-cyan-500/20\" data-kid=\"185\">\n          <div class=\"max-w-md mx-auto w-full space-y-5\" data-kid=\"186\">\n            <div class=\"space-y-2\" data-kid=\"187\">\n              <div class=\"inline-flex items-center gap-1.5 px-2 py-0.5 rounded bg-[#FF004F]/10 border border-[#FF004F]/30 text-[10px] font-mono-tech text-[#FF004F]\" data-kid=\"188\">\n                <span class=\"w-1.5 h-1.5 rounded-full bg-[#FF004F] animate-pulse\" data-kid=\"189\"></span>\n                REGISTRATION CORE ACTIVE\n              </div>\n              <h2 class=\"text-2xl font-hud font-bold text-white tracking-tight\" data-kid=\"190\">Provision Aegis Identifier</h2>\n              <p class=\"text-slate-400 text-xs\" data-kid=\"191\">Establish authorized credentials to access clinical diagnostic AI.</p>\n            </div>\n\n            \n            <form onsubmit=\"switchState('signin'); return false;\" class=\"space-y-3.5\" data-kid=\"192\">\n              <div class=\"space-y-1\" data-kid=\"193\">\n                <label class=\"text-xs font-hud font-bold text-cyan-400 tracking-wider block uppercase\" data-kid=\"194\">FULL NAME / USER OPERATOR</label>\n                <input type=\"text\" value=\"KESAVARDHAN MAKIREDDI\" required class=\"w-full px-4 py-2.5 bg-slate-950/80 border border-cyan-500/30 text-cyan-200 focus:border-[#00FFFF] focus:outline-none focus:ring-1 focus:ring-[#00FFFF] text-xs font-mono-tech rounded\" data-kid=\"195\">\n              </div>\n\n              <div class=\"space-y-1\" data-kid=\"196\">\n                <label class=\"text-xs font-hud font-bold text-cyan-400 tracking-wider block uppercase\" data-kid=\"197\">SECURE EMAIL ADDRESS</label>\n                <input type=\"email\" value=\"kesavardhan775@gmail.com\" required class=\"w-full px-4 py-2.5 bg-slate-950/80 border border-cyan-500/30 text-cyan-200 focus:border-[#00FFFF] focus:outline-none focus:ring-1 focus:ring-[#00FFFF] text-xs font-mono-tech rounded\" data-kid=\"198\">\n              </div>\n\n              <div class=\"grid grid-cols-2 gap-3\" data-kid=\"199\">\n                <div class=\"space-y-1\" data-kid=\"200\">\n                  <label class=\"text-[10px] font-hud font-bold text-cyan-400 tracking-wider block uppercase\" data-kid=\"201\">CHOSE PASSWORD</label>\n                  <input type=\"password\" value=\"Realmegt3t@\" required class=\"w-full px-3 py-2 bg-slate-950/80 border border-cyan-500/30 text-cyan-200 focus:border-[#00FFFF] focus:outline-none focus:ring-1 focus:ring-[#00FFFF] text-xs font-mono-tech rounded\" data-kid=\"202\">\n                </div>\n                <div class=\"space-y-1\" data-kid=\"203\">\n                  <label class=\"text-[10px] font-hud font-bold text-cyan-400 tracking-wider block uppercase\" data-kid=\"204\">CONFIRM PASSWORD</label>\n                  <input type=\"password\" value=\"Realmegt3t@\" required class=\"w-full px-3 py-2 bg-slate-950/80 border border-cyan-500/30 text-cyan-200 focus:border-[#00FFFF] focus:outline-none focus:ring-1 focus:ring-[#00FFFF] text-xs font-mono-tech rounded\" data-kid=\"205\">\n                </div>\n              </div>\n\n              <div class=\"p-3 bg-emerald-500/5 border border-emerald-500/20 rounded text-[11px] text-emerald-400 font-mono-tech\" data-kid=\"206\">\n                <div class=\"flex items-center gap-1.5\" data-kid=\"207\"><i class=\"ti ti-circle-check\" data-kid=\"208\"></i> Credentials match cryptographic standard. STRENGTH: HIGH</div>\n              </div>\n\n              <button type=\"submit\" class=\"w-full py-2.5 bg-[#00FFFF] hover:bg-cyan-400 text-slate-950 transition-all font-hud font-bold tracking-widest text-xs uppercase rounded shadow-[0_0_15px_rgba(0,255,255,0.3)]\" data-kid=\"209\">\n                PROVISION DIAGNOSTIC KEY &rarr;\n              </button>\n            </form>\n\n            <p class=\"text-center text-xs font-mono-tech text-slate-500\" data-kid=\"210\">\n              Already have an operator key? <button onclick=\"switchState('signin')\" class=\"text-cyan-400 hover:underline\" data-kid=\"211\">Identify now</button>\n            </p>\n          </div>\n        </div>\n\n        \n        <div class=\"w-1/2 relative overflow-hidden bg-slate-950\" data-kid=\"212\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[#010B13] via-transparent to-[#010B13] z-10\" data-kid=\"213\"></div>\n          <img src=\"https://images.unsplash.com/photo-1763198302535-265c44183bcb?auto=format&w=600&q=80&fit=crop\" alt=\"Cyan skeleton illustration signup\" class=\"w-full h-full object-cover opacity-60 mix-blend-screen\" decoding=\"async\" loading=\"lazy\" data-kid=\"214\">\n          <div class=\"absolute bottom-8 right-8 z-20 bg-slate-950/90 border border-cyan-500/30 p-4 rounded max-w-xs font-mono-tech text-[11px] text-[#00FFFF]\" data-kid=\"215\">\n            <div class=\"font-bold text-white mb-1\" data-kid=\"216\">&lt;BIOMETRIC_IDENTITY_ACTIVE&gt;</div>\n            Anatomical structure matched with cryptographic biometric identifiers.\n          </div>\n        </div>\n\n      </div>\n    </main>\n\n    \n    <footer class=\"border-t border-cyan-500/20 bg-[#010B13]/90 px-6 py-2 flex items-center justify-between text-[10px] font-mono-tech text-cyan-400/60 shrink-0\" data-kid=\"217\">\n      <div data-kid=\"218\">OPERATOR IDENTIFIER: <span class=\"text-slate-300\" data-kid=\"219\">KESAVARDHAN MAKIREDDI</span></div>\n      <div class=\"flex items-center gap-4\" data-kid=\"220\">\n        <div data-kid=\"221\">CRYPTO_TOKEN: <span class=\"text-emerald-400\" data-kid=\"222\">ACTIVE_VALIDATED</span></div>\n        <div data-kid=\"223\">SYS_TEMP: <span class=\"text-slate-300\" data-kid=\"224\">34°C</span></div>\n      </div>\n    </footer>\n\n  </div>\n\n  \n  <script data-kid=\"225\">\n    // Mock database for dynamic prompt trigger feedback\n    const medicalDiagnosticDB = {\n      brain: {\n        title: \"CRANIAL DEEP-DIVE\",\n        question: \"Initiate full neurological cranial scan assessment for chronic severe headaches.\",\n        answer: \"SCAN SEQUENCE COMPLETED: Cranial nerves and ventricular system analyzed. High blood volume localized in left temporal cortex (75 ml/100g). Diagnostic simulation points to benign localized vasomotor reaction (migraine variant). Recommended protocol: hydration telemetry, magnesium supplementation, and targeted photophobia reduction screen time thresholds.\",\n        cbv: \"78 ml/100g\",\n        pulse: \"68 BPM\",\n        warning: \"Warning: Diagnostic output for simulated analysis. Contact a primary care physician.\"\n      },\n      cardio: {\n        title: \"CARDIO TELEMETRY ANALYSIS\",\n        question: \"Validate current cardio telemetry feedback, pressure anomalies, and active EKG pulse rates.\",\n        answer: \"TELEMETRY SYNCHRONIZED: Cardiac cycle output exhibits healthy sinus waveform pattern. Rate fluctuates within normal parameters (72 BPM nominal baseline). Left ventricular stroke volume: 82ml. Pressure profile: 118/76 mmHg. No localized ST-segment elevation detected in mock leads.\",\n        cbv: \"42 ml/100g\",\n        pulse: \"72 BPM\",\n        warning: \"Warning: Diagnostic output for simulated analysis. Contact a primary care physician.\"\n      },\n      skeletal: {\n        title: \"SKELETAL MAP RESOLUTION\",\n        question: \"Request high resolution skeletal X-Ray bone density analysis for localized fracture anomalies.\",\n        answer: \"X-RAY MATRIX RECONSTRUCTED: 3D density maps of vertebrae and cervical segment completed. Structurally intact with nominal calcium distribution. Intervertebral spaces within standard biometric limits. No signs of stress microfractures or disk herniation.\",\n        cbv: \"15 ml/100g\",\n        pulse: \"75 BPM\",\n        warning: \"Warning: Diagnostic output for simulated analysis. Contact a primary care physician.\"\n      }\n    };\n\n    // State switcher function\n    function switchState(targetState) {\n      const mainContainer = document.getElementById('main-container');\n      \n      // Update data attribute\n      mainContainer.setAttribute('data-active-tab', targetState);\n\n      // Hide all main screen elements\n      document.getElementById('screen-terminal').classList.add('hidden');\n      document.getElementById('screen-signin').classList.add('hidden');\n      document.getElementById('screen-signup').classList.add('hidden');\n\n      // Unset active class on all nav tabs\n      const tabs = ['terminal', 'signin', 'signup'];\n      tabs.forEach(t => {\n        const btn = document.getElementById(`tab-btn-${t}`);\n        if (btn) {\n          btn.className = \"px-4 py-1.5 text-xs font-hud tracking-widest text-slate-400 hover:text-cyan-400 hover:bg-cyan-950/20 transition-all duration-300 flex items-center gap-2 border-b-2 border-transparent\";\n        }\n      });\n\n      // Show the selected screen\n      const targetScreen = document.getElementById(`screen-${targetState}`);\n      if (targetScreen) {\n        targetScreen.classList.remove('hidden');\n        if (targetState === 'terminal') {\n          targetScreen.classList.add('flex');\n        }\n      }\n\n      // Highlight active tab\n      const activeBtn = document.getElementById(`tab-btn-${targetState}`);\n      if (activeBtn) {\n        activeBtn.className = \"px-4 py-1.5 text-xs font-hud tracking-widest transition-all duration-300 flex items-center gap-2 bg-[#00FFFF]/10 border-b-2 border-[#00FFFF] text-[#00FFFF] font-bold\";\n      }\n\n      // Simulated computer telemetry sound\n      playBeep(200, 440);\n    }\n\n    // Audio synthesizer function for retro sci-fi HUD experience\n    function playBeep(duration = 100, frequency = 440) {\n      try {\n        const AudioContext = window.AudioContext || window.webkitAudioContext;\n        if (!AudioContext) return;\n        const ctx = new AudioContext();\n        const osc = ctx.createOscillator();\n        const gain = ctx.createGain();\n        osc.connect(gain);\n        gain.connect(ctx.destination);\n        osc.frequency.value = frequency;\n        osc.type = 'sine';\n        gain.gain.setValueAtTime(0.04, ctx.currentTime);\n        gain.gain.exponentialRampToValueAtTime(0.00001, ctx.currentTime + duration/1000);\n        osc.start();\n        osc.stop(ctx.currentTime + duration/1000);\n      } catch (e) {\n        // Prevent browser safety blockage\n      }\n    }\n\n    // Function to handle quick diagnostic targets click\n    function triggerQuickQuery(targetKey) {\n      const data = medicalDiagnosticDB[targetKey];\n      if (!data) return;\n\n      // Swap active visual container\n      const visuals = ['brain', 'cardio', 'skeletal'];\n      visuals.forEach(v => {\n        const visNode = document.getElementById(`visual-${v}`);\n        if (v === targetKey) {\n          visNode.classList.remove('opacity-0', 'pointer-events-none');\n          visNode.classList.add('opacity-100');\n        } else {\n          visNode.classList.add('opacity-0', 'pointer-events-none');\n          visNode.classList.remove('opacity-100');\n        }\n      });\n\n      // Show conversation UI elements\n      document.getElementById('terminal-diagnostics-welcome').classList.add('hidden');\n      document.getElementById('active-conversation-stream').classList.remove('hidden');\n\n      // Update dialog text\n      document.getElementById('chat-user-question').innerText = data.question;\n      \n      // Update metric readouts\n      document.getElementById('metric-cbv').innerText = data.cbv;\n      document.getElementById('metric-pulse').innerText = data.pulse;\n\n      // Fast letters print typing telemetry effect\n      const answerElement = document.getElementById('chat-ai-answer');\n      answerElement.innerText = '';\n      let index = 0;\n      playBeep(300, 880);\n      \n      function typeText() {\n        if (index < data.answer.length) {\n          answerElement.innerText += data.answer.charAt(index);\n          index++;\n          // Beep randomly as keys type for sound design\n          if (index % 12 === 0) {\n            playBeep(30, 1200);\n          }\n          setTimeout(typeText, 4);\n        }\n      }\n      typeText();\n    }\n\n    // Input form trigger custom question\n    function handleChatSubmit(e) {\n      e.preventDefault();\n      const input = document.getElementById('chat-input');\n      const text = input.value.trim();\n      if (!text) return;\n\n      // Determine matching visualization category based on words\n      let targetCategory = 'brain';\n      if (text.toLowerCase().includes('heart') || text.toLowerCase().includes('cardio') || text.toLowerCase().includes('pulse') || text.toLowerCase().includes('blood')) {\n        targetCategory = 'cardio';\n      } else if (text.toLowerCase().includes('bone') || text.toLowerCase().includes('skeleton') || text.toLowerCase().includes('xray') || text.toLowerCase().includes('fracture')) {\n        targetCategory = 'skeletal';\n      }\n\n      // Populate user question text\n      document.getElementById('chat-user-question').innerText = text;\n      input.value = '';\n\n      // Trigger standard workflow\n      triggerQuickQuery(targetCategory);\n    }\n  </script>\n</div>\n",
