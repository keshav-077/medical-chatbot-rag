      "generation": {
        "prompt": "",
        "config": {}
      },
      "html": "\n<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  /* Custom Styles for Bioluminescent Aurora Dashboard */\n  .custom-dashboard-font {\n    font-family: 'Outfit', sans-serif;\n  }\n\n  /* Morphing Blob Animation (with base organic rounded-shape to prevent square flash) */\n  @keyframes morph {\n    0% {\n      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;\n    }\n    50% {\n      border-radius: 40% 60% 70% 30% / 50% 60% 30% 70%;\n    }\n    100% {\n      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;\n    }\n  }\n  .animate-morph {\n    animation: morph 6s ease-in-out infinite;\n  }\n\n  /* Gentle floating animation for background orbs */\n  @keyframes float-slow {\n    0%, 100% { transform: translateY(0px) scale(1); }\n    50% { transform: translateY(-15px) scale(1.03); }\n  }\n  .animate-float {\n    animation: float-slow 10s ease-in-out infinite;\n  }\n  .animate-float-delayed {\n    animation: float-slow 12s ease-in-out infinite;\n    animation-delay: 1.5s;\n  }\n</style>\n\n\n<div class=\"custom-dashboard-font relative w-[1280px] h-[800px] bg-[#F0FFFF] overflow-hidden flex flex-row p-4 select-none\" data-kid=\"1\">\n  \n  \n  <div class=\"absolute inset-0 pointer-events-none overflow-hidden z-0\" data-kid=\"2\">\n    \n    <div class=\"absolute -top-[10%] -left-[10%] w-[500px] h-[500px] rounded-full bg-[#81D8D0]/30 blur-[80px] animate-float\" data-kid=\"3\"></div>\n    \n    <div class=\"absolute -bottom-[10%] right-[15%] w-[450px] h-[450px] rounded-full bg-[#FF91A4]/25 blur-[90px] animate-float-delayed\" data-kid=\"4\"></div>\n    \n    <div class=\"absolute top-[30%] left-[35%] w-[350px] h-[350px] rounded-full bg-[#81D8D0]/15 blur-[100px]\" data-kid=\"5\"></div>\n  </div>\n\n  \n  <div class=\"relative z-10 w-full h-full flex flex-row gap-4\" data-kid=\"6\">\n\n    \n    <aside class=\"w-[260px] shrink-0 h-full bg-white/40 backdrop-blur-2xl border border-white/40 shadow-sm rounded-3xl flex flex-col justify-between p-4 [box-shadow:inset_0_1px_0_rgba(255,255,255,0.8)]\" data-kid=\"7\">\n      \n      \n      <div class=\"flex flex-col gap-5 overflow-hidden\" data-kid=\"8\">\n        \n        <div class=\"flex items-center gap-3 px-2\" data-kid=\"9\">\n          <div class=\"w-10 h-10 rounded-2xl bg-gradient-to-tr from-[#3457D5]/70 to-[#81D8D0]/70 flex items-center justify-center text-white shadow-xs\" data-kid=\"10\">\n            <i class=\"ti ti-pulse text-xl\" data-kid=\"11\"></i>\n          </div>\n          <div data-kid=\"12\">\n            <h1 class=\"text-[#3457D5] font-bold text-lg leading-tight tracking-tight\" data-kid=\"13\">AuraMed</h1>\n            <p class=\"text-xs text-[#3457D5]/60 font-medium\" data-kid=\"14\">Bioluminescent AI</p>\n          </div>\n        </div>\n\n        \n        <button class=\"w-full py-3 px-4 bg-white/60 hover:bg-white/80 active:bg-white/90 border border-white/50 text-[#3457D5] rounded-2xl font-semibold flex items-center justify-center gap-2 transition-all duration-300 shadow-xs hover:shadow-md hover:-translate-y-0.5 cursor-pointer\" data-kid=\"15\">\n          <i class=\"ti ti-plus text-lg\" data-kid=\"16\"></i>\n          <span data-kid=\"17\">New Consultation</span>\n        </button>\n\n        \n        <div class=\"flex flex-col gap-2 overflow-hidden\" data-kid=\"18\">\n          <span class=\"text-xs font-semibold text-[#3457D5]/40 tracking-wider uppercase px-2\" data-kid=\"19\">Recent Sessions</span>\n          \n          <div class=\"flex flex-col gap-1.5 overflow-y-auto pr-1 max-h-[360px]\" data-kid=\"20\">\n            \n            <div class=\"group flex items-center gap-3 p-3 rounded-2xl bg-white/70 border border-white/60 shadow-xs cursor-pointer transition-all duration-200\" data-kid=\"21\">\n              <div class=\"w-8 h-8 rounded-xl bg-[#81D8D0]/30 flex items-center justify-center text-[#3457D5] shrink-0\" data-kid=\"22\">\n                <i class=\"ti ti-activity text-md\" data-kid=\"23\"></i>\n              </div>\n              <div class=\"min-w-0 flex-1\" data-kid=\"24\">\n                <p class=\"text-xs font-semibold text-[#3457D5] truncate\" data-kid=\"25\">General Health Diagnostics</p>\n                <p class=\"text-[10px] text-[#3457D5]/50\" data-kid=\"26\">Active • 2m ago</p>\n              </div>\n            </div>\n\n            \n            <div class=\"group flex items-center gap-3 p-3 rounded-2xl hover:bg-white/40 border border-transparent hover:border-white/20 cursor-pointer transition-all duration-200\" data-kid=\"27\">\n              <div class=\"w-8 h-8 rounded-xl bg-white/50 flex items-center justify-center text-[#3457D5]/70 shrink-0 group-hover:bg-white/80 transition-all\" data-kid=\"28\">\n                <i class=\"ti ti-brain text-md\" data-kid=\"29\"></i>\n              </div>\n              <div class=\"min-w-0 flex-1\" data-kid=\"30\">\n                <p class=\"text-xs font-medium text-slate-700 truncate\" data-kid=\"31\">Sleep Cycle Disruption</p>\n                <p class=\"text-[10px] text-slate-400\" data-kid=\"32\">Completed • Yesterday</p>\n              </div>\n            </div>\n\n            \n            <div class=\"group flex items-center gap-3 p-3 rounded-2xl hover:bg-white/40 border border-transparent hover:border-white/20 cursor-pointer transition-all duration-200\" data-kid=\"33\">\n              <div class=\"w-8 h-8 rounded-xl bg-white/50 flex items-center justify-center text-[#3457D5]/70 shrink-0 group-hover:bg-white/80 transition-all\" data-kid=\"34\">\n                <i class=\"ti ti-pepper text-md\" data-kid=\"35\"></i>\n              </div>\n              <div class=\"min-w-0 flex-1\" data-kid=\"36\">\n                <p class=\"text-xs font-medium text-slate-700 truncate\" data-kid=\"37\">Nutrition & Vitality Assessment</p>\n                <p class=\"text-[10px] text-slate-400\" data-kid=\"38\">Completed • 4 days ago</p>\n              </div>\n            </div>\n\n            \n            <div class=\"group flex items-center gap-3 p-3 rounded-2xl hover:bg-white/40 border border-transparent hover:border-white/20 cursor-pointer transition-all duration-200\" data-kid=\"39\">\n              <div class=\"w-8 h-8 rounded-xl bg-white/50 flex items-center justify-center text-[#3457D5]/70 shrink-0 group-hover:bg-white/80 transition-all\" data-kid=\"40\">\n                <i class=\"ti ti-heart-rate-monitor text-md\" data-kid=\"41\"></i>\n              </div>\n              <div class=\"min-w-0 flex-1\" data-kid=\"42\">\n                <p class=\"text-xs font-medium text-slate-700 truncate\" data-kid=\"43\">Cardio Stress Evaluation</p>\n                <p class=\"text-[10px] text-slate-400\" data-kid=\"44\">Completed • Oct 12, 2026</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"bg-white/50 border border-white/60 rounded-2xl p-3 flex items-center gap-3 shadow-xs\" data-kid=\"45\">\n        <div class=\"relative\" data-kid=\"46\">\n          <img src=\"https://i.pravatar.cc/80?u=auramedic\" alt=\"User Avatar\" class=\"w-10 h-10 rounded-xl object-cover border border-white\" decoding=\"async\" loading=\"lazy\" data-kid=\"47\">\n          <span class=\"absolute bottom-0 right-0 w-3 h-3 bg-emerald-400 border-2 border-white rounded-full animate-pulse\" data-kid=\"48\"></span>\n        </div>\n        <div class=\"min-w-0 flex-1\" data-kid=\"49\">\n          <p class=\"text-xs font-bold text-[#3457D5]\" data-kid=\"50\">Dr. Elena Rostova</p>\n          <p class=\"text-[10px] text-[#3457D5]/60 font-medium truncate\" data-kid=\"51\">Chief Resident • On duty</p>\n        </div>\n        <button class=\"w-7 h-7 rounded-lg hover:bg-[#FF91A4]/10 hover:text-[#FF91A4] flex items-center justify-center text-[#3457D5]/50 transition-all cursor-pointer\" data-kid=\"52\">\n          <i class=\"ti ti-settings text-md\" data-kid=\"53\"></i>\n        </button>\n      </div>\n\n    </aside>\n\n    \n    <main class=\"flex-1 h-full flex flex-col justify-between overflow-hidden\" data-kid=\"54\">\n      \n      \n      <header class=\"h-[60px] bg-white/40 backdrop-blur-2xl border border-white/40 shadow-sm rounded-2xl flex items-center justify-between px-5 [box-shadow:inset_0_1px_0_rgba(255,255,255,0.8)] shrink-0\" data-kid=\"55\">\n        <div class=\"flex items-center gap-3\" data-kid=\"56\">\n          <div class=\"flex items-center gap-1.5 text-xs text-[#3457D5]/50 font-medium\" data-kid=\"57\">\n            <span data-kid=\"58\">Home</span>\n            <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"59\"></i>\n            <span data-kid=\"60\">Diagnostics</span>\n            <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"61\"></i>\n            <span class=\"text-[#3457D5] font-semibold\" data-kid=\"62\">General Consultation</span>\n          </div>\n        </div>\n        \n        <div class=\"flex items-center gap-2\" data-kid=\"63\">\n          <span class=\"px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-600 text-[10px] font-bold tracking-wider uppercase flex items-center gap-1.5\" data-kid=\"64\">\n            <span class=\"w-1.5 h-1.5 bg-emerald-500 rounded-full animate-ping\" data-kid=\"65\"></span>\n            Secure Consultation\n          </span>\n        </div>\n      </header>\n\n      \n      <div class=\"flex-1 my-3 bg-white/40 backdrop-blur-2xl border border-white/40 shadow-sm rounded-3xl [box-shadow:inset_0_1px_0_rgba(255,255,255,0.8)] flex flex-row items-center justify-between p-8 relative overflow-hidden gap-8\" data-kid=\"66\">\n        \n        \n        <div class=\"flex-1 flex flex-col justify-center text-left z-10 max-w-[440px]\" data-kid=\"67\">\n          <div class=\"inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[#81D8D0]/20 text-[#3457D5] text-xs font-bold w-fit mb-4\" data-kid=\"68\">\n            <i class=\"ti ti-sparkles text-amber-500\" data-kid=\"69\"></i>\n            <span data-kid=\"70\">AuraMed Engine Active</span>\n          </div>\n          \n          <h2 class=\"text-3xl font-extrabold text-[#3457D5] tracking-tight mb-3\" data-kid=\"71\">Start a New Conversation</h2>\n          <p class=\"text-sm text-slate-600 leading-relaxed mb-6\" data-kid=\"72\">\n            Ask anything about medical topics, symptoms, or diagnostic values. Our premium refractive AI engine processes input securely with clinical compliance.\n          </p>\n\n          \n          <div class=\"flex flex-col gap-2\" data-kid=\"73\">\n            <span class=\"text-[11px] font-bold text-[#3457D5]/40 tracking-wider uppercase\" data-kid=\"74\">SUGGESTED DISCUSSIONS</span>\n            <button class=\"w-full flex items-center gap-3 p-2.5 bg-white/70 hover:bg-white border border-white/80 rounded-xl text-left text-xs font-semibold text-slate-700 hover:border-[#81D8D0] shadow-2xs hover:shadow-xs transition-all duration-200 cursor-pointer\" data-kid=\"75\">\n              <span class=\"text-base\" data-kid=\"76\">🧬</span>\n              <span class=\"truncate\" data-kid=\"77\">\"Analyze my recent blood allergy patterns\"</span>\n            </button>\n            <button class=\"w-full flex items-center gap-3 p-2.5 bg-white/70 hover:bg-white border border-white/80 rounded-xl text-left text-xs font-semibold text-slate-700 hover:border-[#81D8D0] shadow-2xs hover:shadow-xs transition-all duration-200 cursor-pointer\" data-kid=\"78\">\n              <span class=\"text-base\" data-kid=\"79\">🫁</span>\n              <span class=\"truncate\" data-kid=\"80\">\"Explain my latest pulmonary assessment reports\"</span>\n            </button>\n          </div>\n        </div>\n\n        \n        <div class=\"w-[380px] h-[320px] rounded-3xl overflow-hidden shadow-xl border-4 border-white/60 relative shrink-0 z-10 transition-transform duration-500 hover:scale-[1.01]\" data-kid=\"81\">\n          \n          <img src=\"https://images.unsplash.com/photo-1626043626790-8c02e556d7ed?auto=format&w=800&q=80&fit=crop\" alt=\"Calming Water Droplets\" class=\"w-full h-full object-cover\" decoding=\"async\" loading=\"lazy\" data-kid=\"82\">\n          \n          \n          <div class=\"absolute inset-0 bg-gradient-to-t from-black/55 via-black/15 to-transparent\" data-kid=\"83\"></div>\n\n          \n          <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"84\">\n            <div class=\"w-20 h-20 bg-[#81D8D0]/95 backdrop-blur-md rounded-full animate-morph flex items-center justify-center text-white shadow-lg shadow-[#81D8D0]/40 transition-all duration-500 hover:scale-110\" data-kid=\"85\">\n              <i class=\"ti ti-heartbeat text-3xl animate-pulse\" data-kid=\"86\"></i>\n            </div>\n          </div>\n        </div>\n\n      </div>\n\n      \n      <div class=\"bg-white/40 backdrop-blur-2xl border border-white/40 shadow-sm rounded-2xl p-3 flex items-center gap-2 [box-shadow:inset_0_1px_0_rgba(255,255,255,0.8)] shrink-0\" data-kid=\"87\">\n        <div class=\"flex items-center gap-2 pl-2\" data-kid=\"88\">\n          \n          <button class=\"w-10 h-10 rounded-xl bg-[#81D8D0]/20 hover:bg-[#81D8D0]/30 text-[#3457D5] flex items-center justify-center transition-all cursor-pointer\" title=\"Voice Input\" data-kid=\"89\">\n            <i class=\"ti ti-microphone text-xl\" data-kid=\"90\"></i>\n          </button>\n          \n          <button class=\"w-10 h-10 rounded-xl hover:bg-white/50 text-[#3457D5]/60 hover:text-[#3457D5] flex items-center justify-center transition-all cursor-pointer\" title=\"Attach Document\" data-kid=\"91\">\n            <i class=\"ti ti-paperclip text-lg\" data-kid=\"92\"></i>\n          </button>\n        </div>\n\n        \n        <div class=\"flex-1 relative\" data-kid=\"93\">\n          <input type=\"text\" placeholder=\"Type your medical question or symptoms...\" class=\"w-full bg-transparent border-0 outline-hidden focus:ring-0 text-sm font-medium text-slate-700 placeholder-slate-400 py-2.5 px-3\" data-kid=\"94\">\n        </div>\n\n        \n        <button class=\"h-11 px-5 bg-[#3457D5] hover:bg-[#2542B3] text-white font-semibold rounded-xl flex items-center gap-2 transition-all duration-300 shadow-[0_4px_12px_rgba(52,87,213,0.3)] hover:shadow-[0_12px_24px_rgba(52,87,213,0.4)] hover:-translate-y-0.5 active:translate-y-0 cursor-pointer\" data-kid=\"95\">\n          <span data-kid=\"96\">Send Message</span>\n          <i class=\"ti ti-send-2 text-md\" data-kid=\"97\"></i>\n        </button>\n      </div>\n\n    </main>\n\n    \n    <aside class=\"w-[300px] shrink-0 h-full flex flex-col gap-4 overflow-hidden\" data-kid=\"98\">\n      \n      \n      <div class=\"bg-white/40 backdrop-blur-2xl border border-white/40 shadow-sm rounded-3xl p-5 [box-shadow:inset_0_1px_0_rgba(255,255,255,0.8)] flex flex-col justify-between h-[360px] relative overflow-hidden\" data-kid=\"99\">\n        \n        \n        <div class=\"absolute bottom-0 left-0 right-0 pointer-events-none h-[120px] opacity-40\" data-kid=\"100\">\n          <svg viewBox=\"0 0 1440 320\" class=\"w-full h-full\" data-kid=\"101\">\n            <path fill=\"#81D8D0\" fill-opacity=\"0.6\" d=\"M0,192L48,197.3C96,203,192,213,288,202.7C384,192,480,160,576,149.3C672,139,768,149,864,170.7C960,192,1056,224,1152,229.3C1248,235,1344,213,1392,202.7L1440,192L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z\" data-kid=\"102\"></path>\n            <path fill=\"#FF91A4\" fill-opacity=\"0.3\" d=\"M0,96L48,112C96,128,192,160,288,181.3C384,203,480,213,576,208C672,203,768,181,864,154.7C960,128,1056,96,1152,106.7C1248,117,1344,171,1392,197.3L1440,224L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z\" data-kid=\"103\"></path>\n          </svg>\n        </div>\n\n        \n        <div class=\"relative z-10\" data-kid=\"104\">\n          <div class=\"flex items-center justify-between mb-4\" data-kid=\"105\">\n            <span class=\"text-xs font-semibold text-slate-400 tracking-wider uppercase\" data-kid=\"106\">Live Patient Vitals</span>\n            <span class=\"w-2.5 h-2.5 bg-rose-500 rounded-full animate-ping\" data-kid=\"107\"></span>\n          </div>\n\n          \n          <div class=\"flex items-baseline gap-2\" data-kid=\"108\">\n            <span class=\"text-4xl font-extrabold text-[#3457D5] tracking-tight\" data-kid=\"109\">42</span>\n            <span class=\"text-xs font-semibold text-emerald-600 bg-emerald-500/10 px-2 py-0.5 rounded-lg flex items-center gap-1\" data-kid=\"110\">\n              <i class=\"ti ti-trending-down\" data-kid=\"111\"></i> Stable (Optimal)\n            </span>\n          </div>\n          <p class=\"text-[11px] text-slate-400 mt-0.5\" data-kid=\"112\">Calculated Stress & Anxiety Index</p>\n        </div>\n\n        \n        <div class=\"relative z-10 bg-white/60 border border-white/70 p-3.5 rounded-2xl shadow-xs\" data-kid=\"113\">\n          <div class=\"flex items-center justify-between mb-1.5\" data-kid=\"114\">\n            <div class=\"flex items-center gap-2\" data-kid=\"115\">\n              <i class=\"ti ti-wave-sine text-md text-[#3457D5]\" data-kid=\"116\"></i>\n              <span class=\"text-xs font-bold text-[#3457D5]\" data-kid=\"117\">Cardio Sync Rate</span>\n            </div>\n            <span class=\"text-xs font-bold text-[#3457D5]\" data-kid=\"118\">72 BPM</span>\n          </div>\n          \n          \n          <div class=\"flex items-end justify-between gap-[2px] h-12 pt-2\" data-kid=\"119\">\n            <div class=\"w-1 bg-[#81D8D0] rounded-full h-[40%]\" data-kid=\"120\"></div>\n            <div class=\"w-1 bg-[#81D8D0] rounded-full h-[60%]\" data-kid=\"121\"></div>\n            <div class=\"w-1 bg-[#3457D5] rounded-full h-[90%]\" data-kid=\"122\"></div>\n            <div class=\"w-1 bg-[#FF91A4] rounded-full h-[50%]\" data-kid=\"123\"></div>\n            <div class=\"w-1 bg-[#81D8D0] rounded-full h-[75%]\" data-kid=\"124\"></div>\n            <div class=\"w-1 bg-[#3457D5] rounded-full h-[35%]\" data-kid=\"125\"></div>\n            <div class=\"w-1 bg-[#81D8D0] rounded-full h-[85%]\" data-kid=\"126\"></div>\n            <div class=\"w-1 bg-[#FF91A4] rounded-full h-[45%]\" data-kid=\"127\"></div>\n            <div class=\"w-1 bg-[#3457D5] rounded-full h-[60%]\" data-kid=\"128\"></div>\n            <div class=\"w-1 bg-[#81D8D0] rounded-full h-[100%]\" data-kid=\"129\"></div>\n            <div class=\"w-1 bg-[#81D8D0] rounded-full h-[40%]\" data-kid=\"130\"></div>\n            <div class=\"w-1 bg-[#FF91A4] rounded-full h-[70%]\" data-kid=\"131\"></div>\n            <div class=\"w-1 bg-[#3457D5] rounded-full h-[85%]\" data-kid=\"132\"></div>\n            <div class=\"w-1 bg-[#81D8D0] rounded-full h-[50%]\" data-kid=\"133\"></div>\n            <div class=\"w-1 bg-[#81D8D0] rounded-full h-[65%]\" data-kid=\"134\"></div>\n          </div>\n        </div>\n\n      </div>\n\n      \n      <div class=\"bg-white/40 backdrop-blur-2xl border border-white/40 shadow-sm rounded-3xl p-5 [box-shadow:inset_0_1px_0_rgba(255,255,255,0.8)] flex-1 flex flex-col justify-between overflow-hidden\" data-kid=\"135\">\n        \n        <div class=\"flex flex-col gap-3 overflow-hidden\" data-kid=\"136\">\n          <div class=\"flex items-center justify-between\" data-kid=\"137\">\n            <span class=\"text-xs font-semibold text-slate-400 tracking-wider uppercase\" data-kid=\"138\">Medical Dossier</span>\n            <button class=\"text-xs font-bold text-[#3457D5] hover:underline cursor-pointer\" data-kid=\"139\">View All</button>\n          </div>\n\n          \n          <div class=\"border border-white/60 bg-white/70 hover:bg-white rounded-2xl p-3 flex items-center justify-between cursor-pointer group transition-all duration-300 shadow-2xs\" data-kid=\"140\">\n            <div class=\"flex items-center gap-3\" data-kid=\"141\">\n              <div class=\"w-9 h-9 rounded-xl bg-[#81D8D0]/20 flex items-center justify-center text-[#3457D5] transition-all\" data-kid=\"142\">\n                <i class=\"ti ti-upload text-lg\" data-kid=\"143\"></i>\n              </div>\n              <div data-kid=\"144\">\n                <span class=\"text-xs font-bold text-[#3457D5] block\" data-kid=\"145\">Upload Reports</span>\n                <span class=\"text-[9px] text-slate-400\" data-kid=\"146\">PDF, DICOM scan files</span>\n              </div>\n            </div>\n            <i class=\"ti ti-plus text-[#3457D5] group-hover:rotate-90 transition-all duration-300\" data-kid=\"147\"></i>\n          </div>\n\n          \n          <div class=\"flex flex-col gap-2 overflow-y-auto max-h-[140px] pr-1\" data-kid=\"148\">\n            \n            <div class=\"flex items-center gap-3 p-2 bg-white/60 hover:bg-white border border-white/80 rounded-xl transition-all shadow-2xs\" data-kid=\"149\">\n              <div class=\"w-9 h-9 rounded-lg bg-rose-100 text-rose-600 flex items-center justify-center shrink-0\" data-kid=\"150\">\n                <i class=\"ti ti-file-text text-lg\" data-kid=\"151\"></i>\n              </div>\n              <div class=\"min-w-0 flex-1\" data-kid=\"152\">\n                <p class=\"text-[11px] font-bold text-slate-700 truncate\" data-kid=\"153\">Blood_Chemistry_Panel.pdf</p>\n                <p class=\"text-[9px] text-slate-400\" data-kid=\"154\">3.4 MB • Oct 14</p>\n              </div>\n              <button class=\"text-[#3457D5]/50 hover:text-red-500 cursor-pointer\" data-kid=\"155\">\n                <i class=\"ti ti-trash text-sm\" data-kid=\"156\"></i>\n              </button>\n            </div>\n\n            \n            <div class=\"flex items-center gap-3 p-2 bg-white/60 hover:bg-white border border-white/80 rounded-xl transition-all shadow-2xs\" data-kid=\"157\">\n              <div class=\"w-9 h-9 rounded-lg bg-[#81D8D0]/20 text-[#3457D5] flex items-center justify-center shrink-0\" data-kid=\"158\">\n                <i class=\"ti ti-medical-cross text-lg\" data-kid=\"159\"></i>\n              </div>\n              <div class=\"min-w-0 flex-1\" data-kid=\"160\">\n                <p class=\"text-[11px] font-bold text-slate-700 truncate\" data-kid=\"161\">ECG_Waveform_Telemetry.bin</p>\n                <p class=\"text-[9px] text-slate-400\" data-kid=\"162\">12.8 MB • Oct 13</p>\n              </div>\n              <button class=\"text-[#3457D5]/50 hover:text-red-500 cursor-pointer\" data-kid=\"163\">\n                <i class=\"ti ti-trash text-sm\" data-kid=\"164\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"bg-gradient-to-r from-[#81D8D0]/20 to-[#FF91A4]/10 rounded-2xl p-3 border border-white/50\" data-kid=\"165\">\n          <div class=\"flex items-center gap-2 mb-1\" data-kid=\"166\">\n            <i class=\"ti ti-shield-check text-emerald-600 text-sm\" data-kid=\"167\"></i>\n            <span class=\"text-[11px] font-bold text-[#3457D5]\" data-kid=\"168\">HIPAA Protected Hub</span>\n          </div>\n          <p class=\"text-[10px] text-slate-500 leading-normal\" data-kid=\"169\">\n            Your files and messages are end-to-end encrypted to clinical healthcare grade standards.\n          </p>\n        </div>\n\n      </div>\n\n    </aside>\n\n  </div>\n\n</div>",
